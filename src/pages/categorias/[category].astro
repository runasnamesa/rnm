---
export const prerender = true;
import BaseLayout from '../../layouts/BaseLayout.astro';
import {
  POST_CATEGORIES,
  categorySlug,
  getPostsByCategory,
  postHref,
  type PostCategory,
} from '../../lib/posts';
import { readStoredPosts } from '../../lib/admin';

export async function getStaticPaths() {
  // Always emit every known category so home links never 404.
  return POST_CATEGORIES.map((category) => ({
    params: { category: categorySlug(category) },
    props: { category },
  }));
}

const { category } = Astro.props as { category: PostCategory };
const posts = await getPostsByCategory(category);
const masterPosts = (await readStoredPosts()).filter((post) => post.category === category);
---

<BaseLayout title={`${category} — Runas na Mesa`} description={`Textos da categoria ${category}.`}>
  <section class="category container">
    <a href="/arquivo">← Arquivo completo</a>
    <h1>{category}</h1>
    {masterPosts.length > 0 || posts.length > 0 ? (
      <ul>
        {masterPosts.map((post) => (
          <li>
            <a href={`/texto-mestre/${post.id}`}>
              {post.title}
              <span>{post.description}</span>
            </a>
          </li>
        ))}
        {posts.map((post) => (
          <li>
            <a href={postHref(post)}>
              {post.data.title}
              <span>{post.data.description}</span>
            </a>
          </li>
        ))}
      </ul>
    ) : (
      <p class="empty">
        Ainda não há textos nesta categoria. Explore o
        <a href="/arquivo">arquivo completo</a> ou volte para a
        <a href="/index">taverna</a>.
      </p>
    )}
  </section>
</BaseLayout>

<style>
  .category { max-width: 58rem; padding-block: var(--space-16); }
  .category > a { color: var(--color-starlight-gold); }
  h1 { color: var(--color-ivory); font-family: var(--font-heading); font-size: var(--text-4xl); margin: var(--space-6) 0 var(--space-10); }
  ul { display: grid; gap: var(--space-4); }
  li a { background: var(--surface-card); border: 1px solid var(--border-subtle); border-radius: var(--radius-lg); display: grid; gap: var(--space-2); padding: var(--space-6); }
  li a:hover { border-color: var(--border-strong); }
  li a { color: var(--color-ivory); font-family: var(--font-heading); font-size: var(--text-xl); }
  li span { color: var(--color-ivory-muted); font-family: var(--font-body); font-size: var(--text-base); }
  .empty { color: var(--color-ivory-muted); font-size: var(--text-lg); line-height: 1.7; }
  .empty a { color: var(--color-starlight-gold); }
</style>
