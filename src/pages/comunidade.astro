---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Comunidade — Runas na Mesa" description="Canais da comunidade Runas na Mesa.">
  <section class="page container"><p>Comunidade</p><h1>Em breve, mais lugares à mesa</h1><p>Os canais da comunidade serão anunciados aqui. Até lá, explore os textos e volte para a taverna quando quiser.</p><a href="/index">Voltar para a taverna →</a></section>
</BaseLayout>

<style>.page { max-width: 52rem; padding-block: var(--space-24); } .page > p:first-child, a { color: var(--color-starlight-gold); } h1 { color: var(--color-ivory); font-family: var(--font-heading); font-size: var(--text-4xl); margin: var(--space-4) 0; } .page > p { color: var(--color-ivory-muted); font-size: var(--text-lg); line-height: 1.7; margin-bottom: var(--space-8); }</style>
