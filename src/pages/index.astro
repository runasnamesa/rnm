---
/**
 * Runas na Mesa — Entrada.
 *
 * Não é uma landing page comercial.
 * Não é um portal.
 * Não tem botões, menus, links ou chamadas para ação.
 *
 * É uma experiência narrativa:
 *   TEMPESTADE → LUZ → PORTA → ABERTURA → TAVERNA → BLOG
 *
 * O usuário não "acessa um site".
 * Ele "encontra uma porta no meio da tempestade".
 */
import WelcomeScene from '../components/WelcomeScene/WelcomeExperience.astro';
---

<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Runas na Mesa</title>
    <meta name="robots" content="noindex, nofollow" />

    <style>
      /* Reset absoluto */
      *, *::before, *::after {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }
      html, body {
        width: 100%;
        height: 100%;
        overflow: hidden;
        background: #060B17;
      }
    </style>
  </head>
  <body>
    <WelcomeScene />
  </body>
</html>
