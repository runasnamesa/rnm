---
/**
 * Runas na Mesa — Entrada da Taverna.
 *
 * Experiência narrativa cinematográfica em 15 estados:
 *   Da Tempestade para a Taverna.
 */
import WelcomeExperience from '../components/WelcomeScene/WelcomeExperience.astro';
---

<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Runas na Mesa — Abertura da Taverna</title>
    <meta name="description" content="Sua taverna digital para RPG de mesa. Encontre refúgio da tempestade." />
    <meta name="theme-color" content="#060B17" />
    
    <!-- Preconnect Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;500;600;700&display=swap" rel="stylesheet" />

    <!-- Favicons -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />

    <style>
      *, *::before, *::after {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }
      html, body {
        width: 100%;
        height: 100%;
        overflow: hidden;
        background: #060B17;
      }
    </style>
  </head>
  <body>
    <WelcomeExperience />
  </body>
</html>
