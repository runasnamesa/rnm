---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import IndexHero from '../../components/IndexHero.astro';
import Sidebar from '../../components/Sidebar.astro';
import FeaturedArticle from '../../components/FeaturedArticle.astro';
import ArticleCard from '../../components/ArticleCard.astro';

const posts = (await getCollection('posts'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const featuredPost = posts[0];
const recentPosts = posts.slice(1, 5);
const categories = ['RPG', 'Narrativa', 'Guias', 'Lore', 'Reflexões'];
const categorySlug = (category: string) => category.normalize('NFD').replace(/[\u0300-\u036f]/g, '').toLowerCase();
---

<BaseLayout
  title="Runas na Mesa — Sua Taverna para Histórias Épicas"
  description="Um refúgio acolhedor para jogadores e mestres de RPG. Descanse, aprenda e prepare-se para a próxima aventura."
>
  <IndexHero />

  <div class="index-layout container container--wide">
    <!-- Coluna Principal -->
    <div class="index-main">

      <!-- Seção: Destaque -->
      <section class="index-section" aria-label="História em destaque">
        {featuredPost && <FeaturedArticle {...featuredPost.data} href={`/posts/${featuredPost.id}`} />}
      </section>

      <!-- Seção: Últimos Textos -->
      <section class="index-section" aria-label="Últimos textos">
        <h2 class="section-title">Últimos Textos</h2>
        <div class="articles-grid">
          {recentPosts.map((post) => (
            <ArticleCard {...post.data} href={`/posts/${post.id}`} />
          ))}
        </div>
      </section>

      <!-- Seção: Categorias e Continue Explorando -->
      <section class="index-section explore-section" aria-label="Navegação de categorias">
        <h2 class="section-title">Categorias</h2>
        <ul class="categories-list" role="list">
          {categories.map((cat) => (
            <li><a href={`/categorias/${categorySlug(cat)}`} class="category-link">{cat}</a></li>
          ))}
        </ul>

        <div class="explore-more">
          <h2 class="section-title">Continue Explorando</h2>
          <p class="explore-text">Ainda procurando algo? Visite o <a href="/arquivo">Arquivo Completo</a>.</p>
        </div>
      </section>

    </div>

    <!-- Coluna Lateral (Desktop) -->
    <div class="index-sidebar-col">
      <Sidebar />
    </div>
  </div>
</BaseLayout>

<style>
  .index-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-12);
    padding-bottom: var(--space-24);
  }

  .index-main {
    display: flex;
    flex-direction: column;
    gap: var(--space-16);
  }

  .index-sidebar-col {
    display: none;
  }

  .index-section {
    display: flex;
    flex-direction: column;
  }

  .section-title {
    font-family: var(--font-heading);
    font-size: var(--text-2xl);
    font-weight: var(--weight-medium);
    color: var(--color-starlight-gold);
    margin-bottom: var(--space-8);
    display: flex;
    align-items: center;
    gap: var(--space-4);
  }

  .section-title::after {
    content: '';
    flex-grow: 1;
    height: 1px;
    background: linear-gradient(90deg, var(--border-default), transparent);
  }

  .articles-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
  }

  /* Seção Categorias */
  .explore-section {
    gap: var(--space-12);
  }

  .categories-list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
  }

  .category-link {
    display: inline-block;
    padding: var(--space-2) var(--space-6);
    border: 1px solid var(--border-default);
    border-radius: var(--radius-full);
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--color-ivory-muted);
    transition: all var(--transition-fast);
  }

  .category-link:hover {
    color: var(--color-deep-space);
    background-color: var(--color-starlight-gold);
    border-color: var(--color-starlight-gold);
    box-shadow: 0 0 16px rgba(212, 176, 106, 0.4);
  }

  .explore-text {
    color: var(--color-ivory-muted);
    font-size: var(--text-base);
  }

  .explore-text a {
    color: var(--color-starlight-gold);
    text-decoration: underline;
    text-decoration-color: transparent;
    transition: text-decoration-color var(--transition-fast);
  }

  .explore-text a:hover {
    text-decoration-color: var(--color-starlight-gold);
  }

  /* Responsividade */
  @media (min-width: 640px) {
    .articles-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .index-layout {
      grid-template-columns: 7fr 3fr;
      gap: var(--space-16);
    }

    .index-sidebar-col {
      display: block;
    }
  }

  @media (min-width: 1280px) {
    .index-layout {
      gap: var(--space-20);
    }
  }
</style>
