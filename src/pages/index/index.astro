---
import BaseLayout from '../../layouts/BaseLayout.astro';
import IndexHero from '../../components/IndexHero.astro';
import Sidebar from '../../components/Sidebar.astro';
import FeaturedArticle from '../../components/FeaturedArticle.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import {
  POST_CATEGORIES,
  categorySlug,
  getPublishedPosts,
  postHref,
} from '../../lib/posts';
import { readStoredPosts } from '../../lib/admin';

const posts = await getPublishedPosts();
const masterPosts = (await readStoredPosts()).sort(
  (a, b) => new Date(b.pubDate).valueOf() - new Date(a.pubDate).valueOf(),
);
const featuredPost = masterPosts[0];
const recentMasterPosts = masterPosts.slice(1, 3);
const recentPosts = posts.slice(0, Math.max(0, 4 - recentMasterPosts.length));
---

<BaseLayout
  title="Runas na Mesa — Sua Taverna para Histórias Épicas"
  description="Um refúgio acolhedor para jogadores e mestres de RPG. Descanse, aprenda e prepare-se para a próxima aventura."
>
  <IndexHero />

  <div class="index-layout container container--wide">
    <!-- Coluna Principal -->
    <div class="index-main">

      <!-- Seção: Destaque -->
      <section class="index-section" aria-label="História em destaque">
        {featuredPost && (
          <FeaturedArticle
            title={featuredPost.title}
            description={featuredPost.description}
            readTime={featuredPost.readTime}
            category={featuredPost.category}
            href={`/texto-mestre/${featuredPost.id}`}
          />
        )}
      </section>

      <!-- Seção: Últimos Textos -->
      <section class="index-section" aria-label="Últimos textos">
        <h2 class="section-title">Últimos Textos</h2>
        {recentMasterPosts.length > 0 || recentPosts.length > 0 ? (
          <div class="articles-grid">
            {recentMasterPosts.map((post) => (
              <ArticleCard
                title={post.title}
                description={post.description}
                readTime={post.readTime}
                category={post.category}
                href={`/texto-mestre/${post.id}`}
              />
            ))}
            {recentPosts.map((post) => (
              <ArticleCard
                title={post.data.title}
                description={post.data.description}
                readTime={post.data.readTime}
                category={post.data.category}
                image={post.data.image}
                href={postHref(post)}
              />
            ))}
          </div>
        ) : (
          <p class="empty-hint">
            Ainda não há outros textos publicados. Volte em breve.
          </p>
        )}
      </section>

      <!-- Seção: Categorias e Continue Explorando -->
      <section class="index-section explore-section" aria-label="Navegação de categorias">
        <h2 class="section-title">Categorias</h2>
        <ul class="categories-list" role="list">
          {POST_CATEGORIES.map((cat) => (
            <li><a href={`/categorias/${categorySlug(cat)}`} class="category-link">{cat}</a></li>
          ))}
        </ul>

        <div class="explore-more">
          <h2 class="section-title">Continue Explorando</h2>
          <p class="explore-text">Ainda procurando algo? Visite o <a href="/arquivo">Arquivo Completo</a>.</p>
        </div>
      </section>

    </div>

    <!-- Coluna Lateral (Desktop) -->
    <div class="index-sidebar-col">
      <Sidebar />
    </div>
  </div>
</BaseLayout>

<style>
  .index-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-12);
    padding-bottom: var(--space-24);
  }

  .index-main {
    display: flex;
    flex-direction: column;
    gap: var(--space-16);
  }

  .index-sidebar-col {
    display: none;
  }

  .index-section {
    display: flex;
    flex-direction: column;
  }

  .section-title {
    font-family: var(--font-heading);
    font-size: var(--text-2xl);
    font-weight: var(--weight-medium);
    color: var(--color-starlight-gold);
    margin-bottom: var(--space-8);
    display: flex;
    align-items: center;
    gap: var(--space-4);
  }

  .section-title::after {
    content: '';
    flex-grow: 1;
    height: 1px;
    background: linear-gradient(90deg, var(--border-default), transparent);
  }

  .articles-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
  }

  .empty-hint {
    color: var(--color-ivory-muted);
    font-size: var(--text-base);
  }

  /* Seção Categorias */
  .explore-section {
    gap: var(--space-12);
  }

  .categories-list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
  }

  .category-link {
    display: inline-block;
    padding: var(--space-2) var(--space-6);
    border: 1px solid var(--border-default);
    border-radius: var(--radius-full);
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--color-ivory-muted);
    transition: all var(--transition-fast);
  }

  .category-link:hover {
    color: var(--color-deep-space);
    background-color: var(--color-starlight-gold);
    border-color: var(--color-starlight-gold);
    box-shadow: 0 0 16px rgba(212, 176, 106, 0.4);
  }

  .explore-text {
    color: var(--color-ivory-muted);
    font-size: var(--text-base);
  }

  .explore-text a {
    color: var(--color-starlight-gold);
    text-decoration: underline;
    text-decoration-color: transparent;
    transition: text-decoration-color var(--transition-fast);
  }

  .explore-text a:hover {
    text-decoration-color: var(--color-starlight-gold);
  }

  /* Responsividade */
  @media (min-width: 640px) {
    .articles-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .index-layout {
      grid-template-columns: 7fr 3fr;
      gap: var(--space-16);
    }

    .index-sidebar-col {
      display: block;
    }
  }

  @media (min-width: 1280px) {
    .index-layout {
      gap: var(--space-20);
    }
  }
</style>
