---
export const prerender = false;

import { readStoredPosts, isAuthenticatedCookie } from '../lib/admin';
import { readTasks } from '../lib/tasks';

const isAuthenticated = isAuthenticatedCookie(Astro.cookies);
const posts = isAuthenticated ? await readStoredPosts() : [];
const tasks = isAuthenticated ? (await readTasks()).sort((a, b) => new Date(b.createdAt).valueOf() - new Date(a.createdAt).valueOf()) : [];
const editId = Astro.url.searchParams.get('edit') ?? '';
const initialPost = posts.find((post) => post.id === editId) ?? null;
const initialContent = initialPost?.content ?? '';
const status = Astro.url.searchParams.get('status') ?? '';
const contentLength = initialContent.replace(/<[^>]*>/g, '').trim().length;

const pendingTasks = tasks.filter(t => t.status === 'pending' || t.status === 'in_progress').length;
const doneTasks = tasks.filter(t => t.status === 'done').length;
const today = new Date().toLocaleDateString('pt-BR', { weekday: 'long', day: 'numeric', month: 'long', year: 'numeric' });
---

{isAuthenticated ? (
  <html lang="pt-BR">
    <head>
      <meta charset="utf-8" />
      <meta name="viewport" content="width=device-width, initial-scale=1" />
      <title>Painel do Mestre — Runas na Mesa</title>
      <meta name="robots" content="noindex, nofollow" />
      <link rel="stylesheet" href="/admin.css" />
    </head>
    <body class="admin-body">
      <div class="admin-app">
        <aside class="admin-sidebar" id="admin-sidebar">
          <div class="admin-brand">
            <a href="/admin" class="admin-brand__mark" aria-label="Painel do Mestre">
              <svg width="24" height="24" viewBox="0 0 28 28" fill="none" aria-hidden="true">
                <path d="M14 2L2 14l12 12 12-12L14 2z" stroke="currentColor" stroke-width="1.5" />
                <path d="M14 7l-7 7 7 7 7-7-7-7z" stroke="currentColor" stroke-width="1" opacity=".5" />
                <circle cx="14" cy="14" r="2" fill="currentColor" />
              </svg>
            </a>
            <div>
              <strong>RUNAS NA MESA</strong>
              <span>Painel do Mestre</span>
            </div>
          </div>

          <nav class="admin-nav" aria-label="Navegação administrativa">
            <span class="admin-nav__label">Workspace</span>
            <a class="admin-nav__link admin-nav__link--active" href="#overview">
              <svg viewBox="0 0 24 24" aria-hidden="true"><rect x="3" y="3" width="7" height="7" rx="1" /><rect x="14" y="3" width="7" height="7" rx="1" /><rect x="3" y="14" width="7" height="7" rx="1" /><rect x="14" y="14" width="7" height="7" rx="1" /></svg>
              Visão geral
            </a>
            <a class="admin-nav__link" href="#tasks">
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M9 11l3 3L22 4" /><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11" /></svg>
              Tarefas
              {pendingTasks > 0 && <span class="admin-nav__badge">{pendingTasks}</span>}
            </a>
            <a class="admin-nav__link" href="#editor">
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 20h9" /><path d="M16.5 3.5a2.1 2.1 0 0 1 3 3L8 18l-4 1 1-4Z" /></svg>
              Texto do Mestre
              <span class="admin-nav__badge">{posts.length}</span>
            </a>
            <a class="admin-nav__link" href="#content">
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 5.5A2.5 2.5 0 0 1 6.5 3H20v15H6.5A2.5 2.5 0 0 0 4 20.5Z" /><path d="M4 5.5v15A2.5 2.5 0 0 1 6.5 18H20" /></svg>
              Arquivo
            </a>
          </nav>

          <div class="admin-sidebar__bottom">
            <a class="admin-sidebar__site" href="/index" target="_blank" rel="noreferrer"><span>Ver site público</span><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M14 5h5v5M19 5l-8 8" /><path d="M19 13v5a1 1 0 0 1-1 1H6a1 1 0 0 1-1-1V6a1 1 0 0 1 1-1h5" /></svg></a>
            <form method="POST" action="/api/admin/logout"><button class="admin-logout" type="submit"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M10 17l5-5-5-5" /><path d="M15 12H3" /><path d="M21 19V5a2 2 0 0 0-2-2h-6" /></svg>Sair do painel</button></form>
          </div>
        </aside>

        <main class="admin-main">
          <header class="admin-topbar">
            <button class="admin-menu-button" type="button" aria-label="Abrir menu administrativo" aria-controls="admin-sidebar" aria-expanded="false" id="admin-menu-button"><span></span><span></span><span></span></button>
            <div class="admin-breadcrumb"><span>Workspace</span><b>/</b><strong>Visão geral</strong></div>
            <div class="admin-topbar__actions"><a href="/texto-mestre" target="_blank" rel="noreferrer" class="admin-preview-link">Abrir publicação <span>↗</span></a><div class="admin-user"><span class="admin-user__avatar">M</span><span>Magnus</span><i></i></div></div>
          </header>

          <div class="admin-content">
            <section class="admin-heading" id="overview">
              <div>
                <p class="admin-eyebrow">{today}</p>
                <h1>Bom retorno, Magnus.</h1>
                <p class="admin-lead">{pendingTasks} tarefa(s) pendente(s) — {posts.length} post(s) publicado(s).</p>
              </div>
              <a class="admin-primary-link" href="#editor"><span>+</span> Novo conteúdo</a>
            </section>

            {status === 'saved' && <div class="admin-alert admin-alert--success"><span>✓</span> Post atualizado e publicação atualizada com sucesso.</div>}
            {status === 'created' && <div class="admin-alert admin-alert--success"><span>✓</span> Novo post criado e publicado com sucesso.</div>}
            {status === 'deleted' && <div class="admin-alert admin-alert--success"><span>✓</span> Post excluído com sucesso.</div>}
            {status === 'invalid' && <div class="admin-alert admin-alert--error"><span>!</span> Usuário ou senha inválidos.</div>}

            <section class="admin-stats" aria-label="Resumo do painel">
              <article class="admin-stat">
                <div class="admin-stat__icon admin-stat__icon--gold">✦</div>
                <div>
                  <span>Conteúdos publicados</span>
                  <strong>{posts.length}</strong>
                  <small>Posts independentes</small>
                </div>
              </article>
              <article class="admin-stat">
                <div class="admin-stat__icon admin-stat__icon--green">✓</div>
                <div>
                  <span>Tarefas concluídas</span>
                  <strong>{doneTasks}</strong>
                  <small>De {tasks.length} total</small>
                </div>
              </article>
              <article class="admin-stat">
                <div class="admin-stat__icon admin-stat__icon--blue">◷</div>
                <div>
                  <span>{pendingTasks > 0 ? 'Pendentes' : 'Status'}</span>
                  <strong>{pendingTasks > 0 ? pendingTasks : 'Em dia'}</strong>
                  <small>{pendingTasks > 0 ? 'Tarefa(s) aguardando' : 'Tudo atualizado'}</small>
                </div>
              </article>
              <article class="admin-stat">
                <div class="admin-stat__icon admin-stat__icon--rose">⌁</div>
                <div>
                  <span>Caracteres escritos</span>
                  <strong>{contentLength.toLocaleString('pt-BR')}</strong>
                  <small>No texto atual</small>
                </div>
              </article>
            </section>

            <!-- Tasks Section -->
            <section class="admin-tasks" id="tasks">
              <div class="admin-panel__header">
                <div>
                  <p class="admin-eyebrow">Gerenciamento</p>
                  <h2>Tarefas {tasks.length > 0 && <span style="color: #8a95a5; font-size: 14px; font-weight: 400;">· {tasks.length} no total</span>}</h2>
                </div>
                <button class="admin-primary-link" type="button" id="task-form-open" style="border:0; font-family: inherit;"><span>+</span> Nova tarefa</button>
              </div>
              <div class="admin-tasks__items" id="task-list">
                {tasks.length > 0 ? tasks.map((task) => (
                  <div class="admin-task-item">
                    <span class:list={['admin-task-status', `admin-task-status--${task.status}`]}></span>
                    <div class="admin-task-content">
                      <strong>{task.title}</strong>
                      <small>{task.description}</small>
                    </div>
                    <div class="admin-task-meta">
                      <span class:list={['admin-task-priority', `admin-task-priority--${task.priority}`]}>{task.priority}</span>
                      {task.dueDate && <small style="color: #a5adba; font-size: 9px;">{task.dueDate}</small>}
                    </div>
                    <form method="POST" action="/api/admin/tasks" class="inline-task-form" style="display: contents;">
                      <input type="hidden" name="action" value="delete" />
                      <input type="hidden" name="taskId" value={task.id} />
                      <button type="submit" class="admin-task-delete" aria-label={`Excluir ${task.title}`}>×</button>
                    </form>
                  </div>
                )) : (
                  <p style="color: #a5adba; font-size: 12px; padding: 12px 0;">Nenhuma tarefa ainda. Crie uma para começar a organizar seu trabalho.</p>
                )}
              </div>
            </section>

            <section class="admin-post-list" id="content">
              <div class="admin-panel__header">
                <div>
                  <p class="admin-eyebrow">Biblioteca editorial</p>
                  <h2>Posts publicados</h2>
                </div>
                <a class="admin-panel__link admin-panel__link--compact" href="/admin#editor">+ Novo post</a>
              </div>
              <div class="admin-post-list__items">
                {posts.length > 0 ? posts.map((post) => (
                  <div class="admin-post-list-item-wrapper" style="display: contents;">
                    <a class:list={['admin-post-list__item', { 'admin-post-list__item--active': post.id === editId }]} href={`/admin?edit=${post.id}#editor`}>
                      <span class="admin-post-list__status"></span>
                      <div>
                        <strong>{post.title}</strong>
                        <small>{post.category} · {post.pubDate}</small>
                      </div>
                      <span class="admin-post-list__arrow">→</span>
                    </a>
                    <form method="POST" action="/api/admin/delete" class="admin-post-list__delete-form" style="display: contents;" onsubmit={`return confirm('Excluir o post "${post.title.replace(/'/g, "\\'")}"? Esta ação não pode ser desfeita.')`}>
                      <input type="hidden" name="postId" value={post.id} />
                      <button type="submit" class="admin-task-delete" aria-label={`Excluir ${post.title}`} style="margin-left: -30px; position: relative; z-index: 2;">×</button>
                    </form>
                  </div>
                )) : (
                  <p style="color: #a5adba; font-size: 12px; padding: 12px;">Nenhum post publicado ainda.</p>
                )}
              </div>
            </section>

            <section class="admin-grid">
              <article class="admin-panel admin-panel--editor" id="editor">
                <div class="admin-panel__header">
                  <div>
                    <p class="admin-eyebrow">Publicação principal</p>
                    <h2>Texto do Mestre</h2>
                  </div>
                  <span class="admin-live"><i></i> Ao vivo</span>
                </div>
                <p class="admin-panel__description">Escreva e atualize o conteúdo que aparece na página pública da taverna.</p>
                <form method="POST" action="/api/admin/save" class="admin-editor-form">
                  <input type="hidden" name="postId" value={initialPost?.id ?? ''} />
                  <div class="admin-post-fields">
                    <label>Título<input name="title" value={initialPost?.title ?? ''} placeholder="Título do novo post" required /></label>
                    <label>Descrição<input name="description" value={initialPost?.description ?? ''} placeholder="Resumo para a home e o arquivo" required /></label>
                    <label>Categoria<input name="category" value={initialPost?.category ?? 'Narrativa'} required /></label>
                  </div>
                  <div class="admin-editor-toolbar"><span>HTML permitido</span><span class="admin-editor-toolbar__hint">O conteúdo será publicado em /texto-mestre</span></div>
                  <textarea name="content" spellcheck="true" aria-label="Conteúdo do Mestre">{initialContent}</textarea>
                  <div class="admin-editor-footer">
                    <span>Salvamento manual</span>
                    <button type="submit" class="admin-save-button">Salvar publicação <span>→</span></button>
                  </div>
                </form>
              </article>

              <div class="admin-side-panels">
                <article class="admin-panel admin-activity" id="activity">
                  <div class="admin-panel__header">
                    <div>
                      <p class="admin-eyebrow">Monitoramento</p>
                      <h2>Atividade recente</h2>
                    </div>
                    <span class="admin-more">•••</span>
                  </div>
                  <div class="admin-activity__item">
                    <span class="admin-activity__dot admin-activity__dot--gold"></span>
                    <div>
                      <strong>{posts.length} posts publicados</strong>
                      <small>{posts.length} publicação(ões) na biblioteca</small>
                    </div>
                  </div>
                  <div class="admin-activity__item">
                    <span class="admin-activity__dot admin-activity__dot--green"></span>
                    <div>
                      <strong>{doneTasks} tarefas concluídas</strong>
                      <small>{pendingTasks} pendente(s) · {tasks.filter(t => t.status === 'cancelled').length} cancelada(s)</small>
                    </div>
                  </div>
                  <div class="admin-activity__item">
                    <span class="admin-activity__dot admin-activity__dot--green"></span>
                    <div>
                      <strong>Publicação disponível</strong>
                      <small>Visível na home e no arquivo</small>
                    </div>
                  </div>
                  <a class="admin-panel__link" href="/arquivo">Ver arquivo público <span>→</span></a>
                </article>

                <article class="admin-panel admin-quick" id="settings">
                  <div class="admin-panel__header">
                    <div>
                      <p class="admin-eyebrow">Atalhos</p>
                      <h2>Próximos passos</h2>
                    </div>
                  </div>
                  <a href="#editor">
                    <span class="admin-quick__icon">✎</span>
                    <div><strong>Continuar escrevendo</strong><small>Voltar para o editor principal</small></div>
                    <b>→</b>
                  </a>
                  <a href="#tasks">
                    <span class="admin-quick__icon">☑</span>
                    <div><strong>Gerenciar tarefas</strong><small>{pendingTasks} tarefa(s) aguardando</small></div>
                    <b>→</b>
                  </a>
                  <a href="/index" target="_blank" rel="noreferrer">
                    <span class="admin-quick__icon">⌂</span>
                    <div><strong>Visitar a taverna</strong><small>Ver a experiência pública</small></div>
                    <b>→</b>
                  </a>
                </article>
              </div>
            </section>

            <footer class="admin-footer">
              <span>Runas na Mesa · Painel do Mestre v2</span>
              <span>Sessão protegida · {tasks.length} tarefas · {posts.length} posts</span>
            </footer>
          </div>
        </main>
      </div>

      <!-- Task Creation Modal -->
      <div class="task-form-overlay" id="task-form-overlay">
        <div class="task-form-modal">
          <h3>Nova tarefa</h3>
          <form id="task-create-form" method="POST" action="/api/admin/tasks">
            <input type="hidden" name="action" value="create" />
            <label>Título<input name="title" placeholder="Ex: Revisar página de lore" required /></label>
            <label>Descrição<textarea name="description" placeholder="Descreva a tarefa..."></textarea></label>
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px;">
              <label>Prioridade
                <select name="priority">
                  <option value="low">Baixa</option>
                  <option value="medium" selected>Média</option>
                  <option value="high">Alta</option>
                  <option value="urgent">Urgente</option>
                </select>
              </label>
              <label>Data limite<input name="dueDate" type="date" /></label>
            </div>
            <div class="task-form-actions">
              <button type="button" class="task-form-cancel" id="task-form-cancel">Cancelar</button>
              <button type="submit" class="task-form-submit">Criar tarefa</button>
            </div>
          </form>
        </div>
      </div>

      <script>
        // Menu mobile
        const menuBtn = document.getElementById('admin-menu-button');
        const sidebar = document.getElementById('admin-sidebar');
        menuBtn?.addEventListener('click', () => {
          const isOpen = sidebar?.classList.toggle('admin-sidebar--open') ?? false;
          menuBtn.setAttribute('aria-expanded', String(isOpen));
        });

        // Task form modal
        const openBtn = document.getElementById('task-form-open');
        const overlay = document.getElementById('task-form-overlay');
        const cancelBtn = document.getElementById('task-form-cancel');
        const taskForm = document.getElementById('task-create-form');

        function openModal() { overlay?.classList.add('task-form-overlay--open'); }
        function closeModal() { overlay?.classList.remove('task-form-overlay--open'); }

        openBtn?.addEventListener('click', openModal);
        cancelBtn?.addEventListener('click', closeModal);
        overlay?.addEventListener('click', (e) => { if (e.target === overlay) closeModal(); });

        // Handle task form via fetch (SPA-like)
        taskForm?.addEventListener('submit', async (e) => {
          e.preventDefault();
          const form = e.currentTarget as HTMLFormElement;
          const data = new FormData(form);
          const json: Record<string, unknown> = {};
          data.forEach((v, k) => {
            if (k === 'tags') {
              json[k] = String(v).split(',').map(s => s.trim()).filter(Boolean);
            } else {
              json[k] = v;
            }
          });

          try {
            const res = await fetch('/api/admin/tasks', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                action: 'create',
                task: {
                  title: json.title,
                  description: json.description || '',
                  priority: json.priority || 'medium',
                  status: 'pending',
                  dueDate: json.dueDate || undefined,
                  assignedTo: 'Magnus',
                  tags: (json.tags as string[]) || [],
                },
              }),
            });
            if (res.ok) {
              window.location.reload();
            } else {
              alert('Erro ao criar tarefa.');
            }
          } catch {
            alert('Erro de conexão.');
          }
        });
      </script>
    </body>
  </html>
) : (
  <html lang="pt-BR">
    <head>
      <meta charset="utf-8" />
      <meta name="viewport" content="width=device-width, initial-scale=1" />
      <title>Entrar no painel — Runas na Mesa</title>
      <meta name="robots" content="noindex, nofollow" />
      <link rel="stylesheet" href="/admin.css" />
    </head>
    <body class="login-body">
      <main class="login-shell">
        <a href="/" class="login-back">← Voltar para a taverna</a>
        <section class="login-card">
          <div class="login-mark">✦</div>
          <p class="admin-eyebrow">Área reservada</p>
          <h1>Bem-vindo ao painel.</h1>
          <p>Entre para administrar as histórias e os segredos da taverna.</p>
          {status === 'invalid' && <div class="admin-alert admin-alert--error"><span>!</span> Credenciais inválidas.</div>}
          <form method="POST" action="/api/admin/login" class="login-form">
            <label for="username">Usuário</label>
            <input id="username" name="username" type="text" autocomplete="username" placeholder="Seu usuário" required />
            <label for="password">Senha</label>
            <input id="password" name="password" type="password" autocomplete="current-password" placeholder="Sua senha" required />
            <button type="submit" class="admin-save-button">Entrar no painel <span>→</span></button>
          </form>
          <small class="login-note">Acesso restrito ao administrador da taverna.</small>
        </section>
      </main>
    </body>
  </html>
)}
