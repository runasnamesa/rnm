---
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
import { readStoredPosts } from '../../lib/admin';

const posts = await readStoredPosts();
const post = posts.find((item) => item.id === Astro.params.slug);

if (!post) {
  return new Response(null, { status: 404, statusText: 'Not found' });
}

const formattedDate = new Intl.DateTimeFormat('pt-BR', {
  day: '2-digit',
  month: 'long',
  year: 'numeric',
}).format(new Date(post.pubDate));
---

<BaseLayout title={`${post.title} — Runas na Mesa`} description={post.description}>
  <article class="post container">
    <a class="post__back" href="/index">← Voltar para a taverna</a>
    <p class="post__meta">{post.category} · {post.readTime} · {formattedDate}</p>
    <h1>{post.title}</h1>
    <p class="post__intro">{post.description}</p>
    <div class="post__content"><Fragment set:html={post.content} /></div>
  </article>
</BaseLayout>

<style>
  .post { max-width: 52rem; padding-block: var(--space-16); }
  .post__back { color: var(--color-starlight-gold); }
  .post__meta { color: var(--color-starlight-gold); font-size: var(--text-sm); letter-spacing: .08em; margin-top: var(--space-8); text-transform: uppercase; }
  h1 { color: var(--color-ivory); font-family: var(--font-heading); font-size: clamp(2.25rem, 6vw, 4rem); line-height: 1.12; margin-top: var(--space-4); }
  .post__intro { color: var(--color-ivory-muted); font-size: var(--text-xl); line-height: 1.6; margin-top: var(--space-6); }
  .post__content { color: var(--color-ivory-muted); font-size: var(--text-lg); line-height: 1.8; margin-top: var(--space-10); }
  .post__content :global(h2) { color: var(--color-ivory); font-family: var(--font-heading); margin-top: var(--space-10); }
  .post__content :global(a) { color: var(--color-starlight-gold); text-decoration: underline; }
</style>
