---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Sobre — Runas na Mesa" description="Conheça a Runas na Mesa.">
  <section class="page container"><p>Sobre</p><h1>Histórias que ficam à mesa</h1><p>Runas na Mesa é uma taverna digital para mestres, jogadores e criadores que querem levar mais imaginação para suas campanhas.</p><a href="/arquivo">Ler os textos →</a></section>
</BaseLayout>

<style>.page { max-width: 52rem; padding-block: var(--space-24); } .page > p:first-child, a { color: var(--color-starlight-gold); } h1 { color: var(--color-ivory); font-family: var(--font-heading); font-size: var(--text-4xl); margin: var(--space-4) 0; } .page > p { color: var(--color-ivory-muted); font-size: var(--text-lg); line-height: 1.7; margin-bottom: var(--space-8); }</style>
