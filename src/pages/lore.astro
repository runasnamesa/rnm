---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Lore — Runas na Mesa" description="Lendas, cenários e histórias para inspirar suas campanhas.">
  <section class="page container"><p>Lore</p><h1>Mapas, lendas e segredos</h1><a href="/categorias/lore">Explorar toda a lore →</a></section>
</BaseLayout>

<style>.page { padding-block: var(--space-24); } p, a { color: var(--color-starlight-gold); } h1 { color: var(--color-ivory); font-family: var(--font-heading); font-size: var(--text-4xl); margin: var(--space-4) 0 var(--space-8); }</style>
