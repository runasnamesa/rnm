---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const posts = (await getCollection('posts', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title="Arquivo — Runas na Mesa" description="Todos os textos da Runas na Mesa.">
  <section class="archive container">
    <p class="eyebrow">Arquivo</p>
    <h1>Todos os textos</h1>
    <div class="archive__list">
      {posts.map((post) => (
        <a href={`/posts/${post.id}`} class="archive__item">
          <span>{post.data.category}</span>
          <strong>{post.data.title}</strong>
          <small>{post.data.description}</small>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .archive { max-width: 58rem; padding-block: var(--space-16); }
  .eyebrow, .archive__item span { color: var(--color-starlight-gold); letter-spacing: .1em; text-transform: uppercase; }
  h1 { color: var(--color-ivory); font-family: var(--font-heading); font-size: var(--text-4xl); margin-top: var(--space-3); }
  .archive__list { display: grid; gap: var(--space-4); margin-top: var(--space-10); }
  .archive__item { background: var(--surface-card); border: 1px solid var(--border-subtle); border-radius: var(--radius-lg); display: grid; gap: var(--space-2); padding: var(--space-6); }
  .archive__item:hover { border-color: var(--border-strong); }
  strong { color: var(--color-ivory); font-family: var(--font-heading); font-size: var(--text-xl); }
  small { color: var(--color-ivory-muted); font-size: var(--text-base); }
</style>
