---
export const prerender = true;
import { render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getPublishedPosts } from '../../lib/posts';

export async function getStaticPaths() {
  const posts = await getPublishedPosts();
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
if (!post || post.data.draft) {
  return new Response(null, { status: 404, statusText: 'Not found' });
}

const { Content } = await render(post);
---

<BaseLayout title={`${post.data.title} — Runas na Mesa`} description={post.data.description} ogImage={post.data.image}>
  <article class="post container">
    <a class="post__back" href="/index">← Voltar para a taverna</a>
    <p class="post__meta">{post.data.category} · {post.data.readTime}</p>
    <h1>{post.data.title}</h1>
    <p class="post__intro">{post.data.description}</p>
    <img class="post__image" src={post.data.image} alt="" />
    <div class="post__content"><Content /></div>
  </article>
</BaseLayout>

<style>
  .post { max-width: 52rem; padding-block: var(--space-16); }
  .post__back { color: var(--color-starlight-gold); }
  .post__meta { color: var(--color-starlight-gold); font-size: var(--text-sm); letter-spacing: .08em; margin-top: var(--space-8); text-transform: uppercase; }
  h1 { color: var(--color-ivory); font-family: var(--font-heading); font-size: clamp(2.25rem, 6vw, 4rem); line-height: 1.12; margin-top: var(--space-4); }
  .post__intro { color: var(--color-ivory-muted); font-size: var(--text-xl); line-height: 1.6; margin-top: var(--space-6); }
  .post__image { border-radius: var(--radius-xl); margin-top: var(--space-10); width: 100%; }
  .post__content { color: var(--color-ivory-muted); font-size: var(--text-lg); line-height: 1.8; margin-top: var(--space-10); }
  .post__content :global(h2) { color: var(--color-ivory); font-family: var(--font-heading); margin-top: var(--space-10); }
  .post__content :global(a) { color: var(--color-starlight-gold); text-decoration: underline; }
</style>
