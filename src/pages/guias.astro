---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Guias — Runas na Mesa" description="Guias para mestres e jogadores.">
  <section class="page container"><p>Guias</p><h1>Ferramentas para a sua mesa</h1><a href="/categorias/guias">Explorar todos os guias →</a></section>
</BaseLayout>

<style>.page { padding-block: var(--space-24); } p, a { color: var(--color-starlight-gold); } h1 { color: var(--color-ivory); font-family: var(--font-heading); font-size: var(--text-4xl); margin: var(--space-4) 0 var(--space-8); }</style>
