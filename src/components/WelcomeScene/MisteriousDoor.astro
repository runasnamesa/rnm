---
/**
 * MisteriousDoor — Porta rúnica que emerge da nevasca.
 * Inspirada nas telas de carregamento de Genshin Impact.
 * Renderiza a porta com runas brilhantes usando Canvas para efeitos de luz.
 */
interface Props {
  width?: number;        // porcentagem da viewport
  height?: number;       // porcentagem da viewport
  glowColor?: string;
  burstColor?: string;
  runeCount?: number;
  runePulseSpeed?: number;
}

const {
  width = 22,
  height = 55,
  glowColor = 'rgba(212, 176, 106, 0.3)',
  burstColor = '#F0D79A',
  runeCount = 5,
  runePulseSpeed = 2.5,
} = Astro.props;
---

<canvas id="door-canvas" class="door-canvas" aria-hidden="true"
  data-width-pct={width}
  data-height-pct={height}
  data-glow={glowColor}
  data-burst={burstColor}
  data-runes={runeCount}
  data-pulse={runePulseSpeed}
></canvas>

<style>
  .door-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 6;
  }
</style>

<script>
  const initializeDoor = () => {
    const canvas = document.getElementById('door-canvas') as HTMLCanvasElement;
    if (!canvas) return;

    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (prefersReducedMotion) return;

    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    let W = 0, H = 0;
    let doorOpacity = 0;
    let isOpen = false;
    let openProgress = 0; // 0–1
    let time = 0;
    let animFrameId: number;
    let isVisible = true;

    const cfg = {
      wPct: parseFloat(canvas.getAttribute('data-width-pct') || '22') / 100,
      hPct: parseFloat(canvas.getAttribute('data-height-pct') || '55') / 100,
      glowColor: canvas.getAttribute('data-glow') || 'rgba(212, 176, 106, 0.3)',
      burstColor: canvas.getAttribute('data-burst') || '#F0D79A',
      runes: parseInt(canvas.getAttribute('data-runes') || '5', 10),
      pulse: parseFloat(canvas.getAttribute('data-pulse') || '2.5'),
    };

    // Rune positions (relative to door center, normalized -1..1)
    const runePositions = [
      { x: 0, y: -0.65 },   // top center
      { x: 0.55, y: -0.35 }, // top right
      { x: 0, y: 0 },        // center
      { x: -0.55, y: 0.35 }, // bottom left
      { x: 0.55, y: 0.45 },  // bottom right
    ];

    // Generate rune paths (simple shapes that look like ancient symbols)
    function generateRunePath(cx: number, cy: number, size: number): Path2D[] {
      const paths: Path2D[] = [];
      const s = size;
      
      // Each rune is composed of 2-3 geometric shapes
      const type = Math.floor(Math.random() * 5);
      const p = new Path2D();
      
      switch (type) {
        case 0: // Diamond + line
          p.moveTo(cx, cy - s);
          p.lineTo(cx + s * 0.6, cy);
          p.lineTo(cx, cy + s);
          p.lineTo(cx - s * 0.6, cy);
          p.closePath();
          paths.push(p);
          { const p2 = new Path2D(); p2.moveTo(cx - s * 0.3, cy); p2.lineTo(cx + s * 0.3, cy); paths.push(p2); }
          break;
        case 1: // Triangle
          p.moveTo(cx, cy - s);
          p.lineTo(cx + s, cy + s * 0.7);
          p.lineTo(cx - s, cy + s * 0.7);
          p.closePath();
          paths.push(p);
          break;
        case 2: // Circle + cross
          p.arc(cx, cy, s * 0.7, 0, Math.PI * 2);
          paths.push(p);
          { const p2 = new Path2D(); p2.moveTo(cx - s * 0.5, cy); p2.lineTo(cx + s * 0.5, cy); paths.push(p2); }
          { const p3 = new Path2D(); p3.moveTo(cx, cy - s * 0.5); p3.lineTo(cx, cy + s * 0.5); paths.push(p3); }
          break;
        case 3: // Arrow
          p.moveTo(cx, cy - s);
          p.lineTo(cx + s * 0.7, cy + s * 0.3);
          p.lineTo(cx + s * 0.3, cy + s * 0.3);
          p.lineTo(cx + s * 0.3, cy + s);
          p.lineTo(cx - s * 0.3, cy + s);
          p.lineTo(cx - s * 0.3, cy + s * 0.3);
          p.lineTo(cx - s * 0.7, cy + s * 0.3);
          p.closePath();
          paths.push(p);
          break;
        case 4: // Hourglass
          p.moveTo(cx - s * 0.7, cy - s);
          p.lineTo(cx + s * 0.7, cy - s);
          p.lineTo(cx - s * 0.7, cy + s);
          p.lineTo(cx + s * 0.7, cy + s);
          p.closePath();
          paths.push(p);
          { const p2 = new Path2D(); p2.moveTo(cx, cy - s); p2.lineTo(cx, cy + s); paths.push(p2); }
          break;
      }
      
      return paths;
    }

    // Pre-generate rune data
    const runeData = runePositions.slice(0, cfg.runes).map((pos, i) => ({
      ...pos,
      phase: Math.random() * Math.PI * 2,
      paths: generateRunePath(pos.x, pos.y, 0.08),
      alpha: 0.4 + Math.random() * 0.3,
    }));

    function drawDoor(c: CanvasRenderingContext2D) {
      const doorW = W * cfg.wPct;
      const doorH = H * cfg.hPct;
      const doorX = (W - doorW) / 2;
      const doorY = (H - doorH) / 2;

      // Clipping region for the door area — draws a glow "clearing" in the snow
      // (the snow canvas reads door position to avoid this area)

      // Outer glow
      if (doorOpacity > 0.01) {
        const glowRadius = Math.max(doorW, doorH) * 0.8;
        const gradient = c.createRadialGradient(W / 2, H / 2, 0, W / 2, H / 2, glowRadius);
        gradient.addColorStop(0, `rgba(212, 176, 106, ${doorOpacity * 0.15})`);
        gradient.addColorStop(0.4, `rgba(212, 176, 106, ${doorOpacity * 0.06})`);
        gradient.addColorStop(1, 'rgba(212, 176, 106, 0)');
        c.fillStyle = gradient;
        c.fillRect(0, 0, W, H);
      }

      // Door frame
      if (doorOpacity < 0.01) return;

      const pulse = 1 + Math.sin(time * cfg.pulse) * 0.04;

      // If opening, apply 3D open transform
      const openAngle = openProgress * Math.PI / 3; // max 60 degrees

      c.save();

      // Move origin to door center for perspective transform
      c.translate(W / 2, H / 2);

      if (isOpen && openProgress > 0) {
        // Simulate door opening: scale X to create "swinging open" effect
        const scaleX = Math.cos(openAngle);
        c.scale(Math.max(0.1, scaleX), 1);
      }

      // === Door shadow ===
      c.shadowColor = `rgba(212, 176, 106, ${doorOpacity * 0.3})`;
      c.shadowBlur = 30 * pulse;

      // Door background (dark wood)
      c.fillStyle = `rgba(10, 16, 38, ${doorOpacity * 0.9})`;
      c.strokeStyle = `rgba(212, 176, 106, ${doorOpacity * 0.7})`;
      c.lineWidth = 3;

      const hw = doorW / 2;
      const hh = doorH / 2;

      // Rounded rect door
      const r = 8;
      c.beginPath();
      c.moveTo(-hw + r, -hh);
      c.lineTo(hw - r, -hh);
      c.quadraticCurveTo(hw, -hh, hw, -hh + r);
      c.lineTo(hw, hh - r);
      c.quadraticCurveTo(hw, hh, hw - r, hh);
      c.lineTo(-hw + r, hh);
      c.quadraticCurveTo(-hw, hh, -hw, hh - r);
      c.lineTo(-hw, -hh + r);
      c.quadraticCurveTo(-hw, -hh, -hw + r, -hh);
      c.closePath();
      c.fill();
      c.stroke();

      c.shadowBlur = 0;

      // === Inner panels ===
      const inset = doorW * 0.08;
      c.strokeStyle = `rgba(212, 176, 106, ${doorOpacity * 0.25})`;
      c.lineWidth = 1;

      // Top panel
      c.strokeRect(-hw + inset, -hh + doorH * 0.1, doorW - inset * 2, doorH * 0.38);
      // Bottom panel
      c.strokeRect(-hw + inset, hh - doorH * 0.48, doorW - inset * 2, doorH * 0.38);

      // === Light leak from door edges ===
      const leakGrad = c.createRadialGradient(0, 0, 0, 0, 0, Math.max(hw, hh));
      leakGrad.addColorStop(0, `rgba(240, 215, 154, ${doorOpacity * 0.05})`);
      leakGrad.addColorStop(1, 'rgba(240, 215, 154, 0)');
      c.fillStyle = leakGrad;
      c.fillRect(-hw, -hh, doorW, doorH);

      // === Runes ===
      const runeScale = doorW * 0.12;
      runeData.forEach((rune) => {
        const rx = rune.x * doorW * 0.35;
        const ry = rune.y * doorH * 0.35;
        const runeAlpha = doorOpacity * rune.alpha * (0.7 + 0.3 * Math.sin(time * cfg.pulse + rune.phase));

        c.save();
        c.translate(rx, ry);
        c.globalAlpha = runeAlpha;
        c.strokeStyle = cfg.burstColor;
        c.lineWidth = 1.5;
        c.shadowColor = `rgba(240, 215, 154, ${runeAlpha * 0.5})`;
        c.shadowBlur = 8 + 4 * Math.sin(time * cfg.pulse + rune.phase);

        rune.paths.forEach(path => {
          c.stroke(path);
        });

        c.restore();
      });

      // === Door handle ===
      const handleX = doorW * 0.35;
      const handleAlpha = doorOpacity * 0.8;
      c.save();
      c.globalAlpha = handleAlpha;
        c.strokeStyle = cfg.burstColor;
      c.lineWidth = 2;
      c.shadowColor = `rgba(240, 215, 154, ${handleAlpha * 0.3})`;
      c.shadowBlur = 10;
      c.beginPath();
      c.arc(handleX, 0, doorW * 0.04, 0, Math.PI * 2);
      c.stroke();
      c.beginPath();
      c.arc(handleX, 0, doorW * 0.023, 0, Math.PI * 2);
      c.fillStyle = `rgba(240, 215, 154, ${handleAlpha * 0.3})`;
      c.fill();
      c.restore();

      c.restore();
    }

    function init() {
      W = window.innerWidth;
      H = window.innerHeight;
      canvas.width = W;
      canvas.height = H;
    }

    let lastTime = 0;
    function render(timestamp: number) {
      if (!isVisible) return;

      const dt = Math.min((timestamp - lastTime) / 16, 3);
      lastTime = timestamp;
      time += dt * 0.016;

      const c = ctx as CanvasRenderingContext2D;
      c.clearRect(0, 0, W, H);

      drawDoor(c);

      animFrameId = requestAnimationFrame(render);
    }

    // Expose controls to parent via window event system
    (window as any).__rnm_door = {
      setOpacity: (op: number) => { doorOpacity = Math.max(0, Math.min(1, op)); },
      getOpacity: () => doorOpacity,
      open: () => { isOpen = true; },
      setOpenProgress: (p: number) => { openProgress = Math.max(0, Math.min(1, p)); },
      getOpenProgress: () => openProgress,
    };

    let resizeTimer: ReturnType<typeof setTimeout>;
    window.addEventListener('resize', () => {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(init, 200);
    });

    document.addEventListener('visibilitychange', () => {
      if (document.hidden) {
        isVisible = false;
        cancelAnimationFrame(animFrameId);
      } else {
        isVisible = true;
        render(performance.now());
      }
    });

    init();
    render(performance.now());
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initializeDoor, { once: true });
  } else {
    initializeDoor();
  }
</script>
</write_to_file>
