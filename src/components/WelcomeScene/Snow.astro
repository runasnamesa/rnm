---
/**
 * Snow — Nevasca cinematográfica com vento, streaks e dissipação ao redor da porta.
 * Representa as dificuldades e ansiedades que o leitor enfrenta antes de encontrar
 * o porto seguro da taverna.
 */
interface Props {
  count?: number;
  maxSize?: number;
  speed?: number;
  wind?: number;
  gust?: number;
  gustStrength?: number;
  turbulence?: number;
  doorAvoidRadius?: number;
  warmTint?: boolean;
  streaks?: boolean;
}

const {
  count = 480,
  maxSize = 4.5,
  speed: speedBase = 1.8,
  wind: windBase = 2.4,
  gust: gustFreq = 1.6,
  gustStrength = 3.0,
  turbulence = 1.2,
  doorAvoidRadius = 0.08,
  warmTint = true,
  streaks = true,
} = Astro.props;
---

<canvas id="snow-canvas" class="snow-canvas" aria-hidden="true"
  data-count={count}
  data-max-size={maxSize}
  data-speed={speedBase}
  data-wind={windBase}
  data-gust={gustFreq}
  data-gust-strength={gustStrength}
  data-turbulence={turbulence}
  data-door-avoid={doorAvoidRadius}
  data-warm-tint={String(warmTint)}
  data-streaks={String(streaks)}
></canvas>

<style>
  .snow-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 5;
  }
</style>

<script>

  const initializeSnow = () => {
    const canvas = document.getElementById('snow-canvas') as HTMLCanvasElement;
    if (!canvas) return;

    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (prefersReducedMotion) return;

    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    let W = 0, H = 0;
    let particles: BlizzardParticle[] = [];
    let windStreaks: WindStreak[] = [];
    let animFrameId: number;
    let isVisible = true;
    let time = 0;
    let doorX = 0, doorY = 0, doorW = 0, doorH = 0;

    const cfg = {
      count: parseInt(canvas.getAttribute('data-count') || '480', 10),
      maxSize: parseFloat(canvas.getAttribute('data-max-size') || '4.5'),
      speed: parseFloat(canvas.getAttribute('data-speed') || '1.8'),
      wind: parseFloat(canvas.getAttribute('data-wind') || '2.4'),
      gust: parseFloat(canvas.getAttribute('data-gust') || '1.6'),
      gustStrength: parseFloat(canvas.getAttribute('data-gust-strength') || '3.0'),
      turbulence: parseFloat(canvas.getAttribute('data-turbulence') || '1.2'),
      doorAvoid: parseFloat(canvas.getAttribute('data-door-avoid') || '0.08'),
      warmTint: canvas.getAttribute('data-warm-tint') === 'true',
      streaks: canvas.getAttribute('data-streaks') === 'true',
    };

    const doorClipW = () => doorW * cfg.doorAvoid;
    const doorClipH = () => doorH * cfg.doorAvoid;

    /** Check if a particle should be cleared near the door. */
    function getDoorRect() {
      return { cx: doorX, cy: doorY, halfW: doorW / 2, halfH: doorH / 2 };
    }

    function isNearDoor(x: number, y: number): boolean {
      const halfW = doorW / 2;
      const halfH = doorH / 2;
      const cx = doorX, cy = doorY;
      const dx = Math.abs(x - cx) - halfW;
      const dy = Math.abs(y - cy) - halfH;
      if (dx > doorClipW() || dy > doorClipH()) return false;
      return true; // Within the clipped rect
    }

    /** Get a door-avoiding spawn position. */
    function spawnPosition(): { x: number; y: number } {
      let x: number, y: number;
      let attempts = 0;
      do {
        x = Math.random() * W;
        y = Math.random() * H;
        attempts++;
      } while (isNearDoor(x, y) && attempts < 50);
      return { x, y };
    }

    class BlizzardParticle {
      x: number; y: number;
      r: number;
      alpha: number;
      windAffinity: number;
      driftX: number;
      driftSpeed: number;
      streakLen: number;
      isStreak: boolean;
      warmGlow: number;

      constructor() {
        const pos = spawnPosition();
        this.x = pos.x;
        this.y = pos.y;
        this.r = Math.random() * cfg.maxSize + 0.3;
        this.alpha = Math.random() * 0.55 + 0.15;
        this.windAffinity = (Math.random() - 0.5) * 1.8;
        this.driftX = (Math.random() - 0.5) * 60;
        this.driftSpeed = Math.random() * 0.02 + 0.005;
        this.streakLen = 0;
        this.isStreak = false;
        this.warmGlow = 0;
      }

      update(dt: number, gustValue: number, angle: number) {
        const baseWind = Math.sin(angle) * cfg.wind;
        const gustWind = gustValue * cfg.gustStrength * this.windAffinity;
        const turbX = Math.sin(time * this.driftSpeed + this.driftX) * cfg.turbulence;
        const turbY = Math.cos(time * this.driftSpeed * 0.7 + this.driftX * 0.5) * cfg.turbulence * 0.3;

        const totalWind = baseWind + gustWind + turbX;
        const fallSpeed = (this.r * 0.6 + 0.4) * cfg.speed;

        this.x += totalWind * dt;
        this.y += (fallSpeed + turbY) * dt;

        // Check if near door → warm glow
        if (cfg.warmTint && isNearDoor(this.x, this.y)) {
          this.warmGlow = Math.min(1, this.warmGlow + 0.02);
          // Push away from door slightly
          const dx = this.x - doorX;
          const dy = this.y - doorY;
          const dist = Math.sqrt(dx * dx + dy * dy) || 1;
          this.x += (dx / dist) * 0.5;
          this.y += (dy / dist) * 0.3;
        } else {
          this.warmGlow = Math.max(0, this.warmGlow - 0.01);
        }

        // Wrap around
        const margin = this.r + 5;
        if (this.y > H + margin) {
          const pos = spawnPosition();
          this.x = pos.x;
          this.y = -margin;
          this.r = Math.random() * cfg.maxSize + 0.3;
          this.alpha = Math.random() * 0.55 + 0.15;
          this.warmGlow = 0;
        }
        if (this.x < -margin) this.x = W + margin;
        if (this.x > W + margin) this.x = -margin;
        if (this.y < -margin) {
          this.y = H + margin;
        }
      }

      draw(c: CanvasRenderingContext2D) {
        // Color: warm gold tint near door, cool white elsewhere
        let r = 248, g = 246, b = 238;
        if (cfg.warmTint && this.warmGlow > 0.01) {
          const w = this.warmGlow;
          r = Math.round(248 + (255 - 248) * w);
          g = Math.round(246 - (246 - 200) * w);
          b = Math.round(238 - (238 - 140) * w);
        }

        const alpha = this.alpha * (cfg.warmTint && this.warmGlow > 0.01 ? 0.9 : 1);
        c.fillStyle = `rgba(${r}, ${g}, ${b}, ${alpha})`;
        c.beginPath();
        c.arc(this.x, this.y, this.r, 0, Math.PI * 2);
        c.fill();
      }
    }

    // Wind streaks — lines that race across the screen horizontally
    class WindStreak {
      x: number; y: number;
      length: number;
      alpha: number;
      speed: number;

      constructor() {
        this.y = Math.random() * H;
        this.x = -50;
        this.length = Math.random() * 80 + 30;
        this.alpha = Math.random() * 0.08 + 0.02;
        this.speed = Math.random() * 12 + 6;
      }

      update(gustValue: number) {
        const gustFactor = 1 + gustValue * 0.8;
        this.x += this.speed * gustFactor;
        if (this.x > W + this.length) {
          this.x = -this.length - 20;
          this.y = Math.random() * H;
          this.alpha = Math.random() * 0.08 + 0.02;
          this.length = Math.random() * 80 + 30;
        }
      }

      draw(c: CanvasRenderingContext2D) {
        c.strokeStyle = `rgba(220, 215, 200, ${this.alpha})`;
        c.lineWidth = 1;
        c.beginPath();
        c.moveTo(this.x, this.y);
        c.lineTo(this.x + this.length, this.y);
        c.stroke();
      }
    }

    function init() {
      W = window.innerWidth;
      H = window.innerHeight;
      canvas.width = W;
      canvas.height = H;

      doorX = W / 2;
      doorY = H / 2;
      doorW = W * 0.22;
      doorH = H * 0.55;

      particles = [];
      for (let i = 0; i < cfg.count; i++) {
        particles.push(new BlizzardParticle());
      }

      windStreaks = [];
      if (cfg.streaks) {
        for (let i = 0; i < 25; i++) {
          windStreaks.push(new WindStreak());
        }
      }
    }

    let lastTime = 0;
    function render(timestamp: number) {
      if (!isVisible) return;

      const dt = Math.min((timestamp - lastTime) / 16, 3);
      lastTime = timestamp;
      time += dt * 0.016;

      (ctx as CanvasRenderingContext2D).clearRect(0, 0, W, H);

      // Gust calculation — smooth waves
      const gustValue = Math.sin(time * cfg.gust * 0.5) * 0.5 +
                         Math.sin(time * cfg.gust * 1.3 + 1.2) * 0.3 +
                         Math.sin(time * cfg.gust * 2.7 + 3.1) * 0.2;
      const angle = time * 0.4;

      const _ctx = ctx as CanvasRenderingContext2D;

      // Draw streaks first (behind particles)
      if (cfg.streaks) {
        windStreaks.forEach(s => {
          s.update(gustValue);
          s.draw(_ctx);
        });
      }

      // Update & draw particles
      particles.forEach(p => {
        p.update(dt, gustValue, angle);
        p.draw(_ctx);
      });

      animFrameId = requestAnimationFrame(render);
    }

    let resizeTimer: ReturnType<typeof setTimeout>;
    window.addEventListener('resize', () => {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(init, 200);
    });

    document.addEventListener('visibilitychange', () => {
      if (document.hidden) {
        isVisible = false;
        cancelAnimationFrame(animFrameId);
      } else {
        isVisible = true;
        lastTime = 0;
        render(performance.now());
      }
    });

    init();
    render(performance.now());
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initializeSnow, { once: true });
  } else {
    initializeSnow();
  }
</script>
