---
/**
 * WelcomeScene — Experiência narrativa de entrada.
 * NÃO é uma landing page. NÃO tem botões, menus ou chamadas para ação.
 *
 * É uma jornada cinematográfica em 15 estados:
 *   TEMPESTADE → LUZ DISTANTE → APROXIMAÇÃO → PORTA → INTERAÇÃO →
 *   ABERTURA → LUZ INVADE → TRAVESSIA → ATRÁS FICOU → REVELAÇÃO →
 *   CÂMERA AJUSTA → PAUSA → BLOG → INTERFACE → EXPLORAR
 *
 * O usuário não "entra no site". Ele "encontra um lugar para descansar".
 */
import StormCanvas from './StormCanvas.astro';
import { WELCOME_CONFIG } from '../../config/welcome.config';
---

<div class="experience" id="experience-root"
  data-storm-alone={WELCOME_CONFIG.timing.stormAlone}
  data-light-appears={WELCOME_CONFIG.timing.lightAppears}
  data-camera-approach={WELCOME_CONFIG.timing.cameraApproach}
  data-door-visible={WELCOME_CONFIG.timing.doorVisible}
  data-door-idle={WELCOME_CONFIG.timing.doorIdle}
  data-door-opening={WELCOME_CONFIG.timing.doorOpening}
  data-light-transition={WELCOME_CONFIG.timing.lightTransition}
  data-tavern-reveal={WELCOME_CONFIG.timing.tavernReveal}
  data-blog-transition={WELCOME_CONFIG.timing.blogTransition}
>
  <StormCanvas
    far={WELCOME_CONFIG.snow.far}
    mid={WELCOME_CONFIG.snow.mid}
    near={WELCOME_CONFIG.snow.near}
    gusts={WELCOME_CONFIG.snow.gusts}
    blur={WELCOME_CONFIG.snow.blur}
    fog={WELCOME_CONFIG.snow.fog}
  />

  <canvas id="door-canvas" class="door-canvas" aria-hidden="true"></canvas>

  <div class="warm-overlay" id="warm-overlay"></div>

  <audio id="ambient-audio" loop preload="none" style="display:none">
    <source src={WELCOME_CONFIG.audio.src} type="audio/mp4" />
  </audio>
</div>

<style>
  .experience {
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
    overflow: hidden;
    background: #060B17;
    cursor: default;
    z-index: 9999;
  }
  .door-canvas {
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 2;
    pointer-events: none;
  }
  .warm-overlay {
    position: fixed;
    inset: 0;
    z-index: 3;
    pointer-events: none;
    opacity: 0;
    background: radial-gradient(circle at center, rgba(240, 215, 154, 0.4) 0%, rgba(212, 176, 106, 0.2) 30%, transparent 60%);
    transition: opacity 2s ease-in-out;
  }
  .warm-overlay--intense {
    background: radial-gradient(circle at center, rgba(255, 248, 230, 0.7) 0%, rgba(240, 215, 154, 0.5) 25%, rgba(212, 176, 106, 0.3) 50%, transparent 75%);
  }
  .warm-overlay--full {
    background: #F0D79A;
    opacity: 1 !important;
    transition: opacity 0.8s ease-in;
  }
  @media (prefers-reduced-motion: reduce) {
    .experience { display: none; }
  }
</style>

<script>
  // ─── Engine ──────────────────────────────────────────────────
  const initializeExperience = () => {
    const root = document.getElementById('experience-root');
    const doorCanvas = document.getElementById('door-canvas') as HTMLCanvasElement;
    const warmOverlay = document.getElementById('warm-overlay') as HTMLElement;
    const audio = document.getElementById('ambient-audio') as HTMLAudioElement;
    const storm = (window as any).__rnm_storm;

    if (!root || !doorCanvas || !warmOverlay) return;

    // ─── Config ──────────────────────────────────────────────
    const T: Record<string, number> = {};
    const attrs = ['storm-alone','light-appears','camera-approach','door-visible','door-idle',
                   'door-opening','light-transition','tavern-reveal','blog-transition'];
    attrs.forEach(a => {
      T[a.replace(/-/g,'')] = parseInt(root.getAttribute('data-'+a) || '3000', 10);
    });

    // ─── Door Setup ──────────────────────────────────────────
    const dCtx = doorCanvas.getContext('2d') as CanvasRenderingContext2D;
    let W = 0, H = 0;
    let doorAlpha = 0, doorOpen = 0, warmAlpha = 0, time = 0;

    function resize() { W = innerWidth; H = innerHeight; doorCanvas.width = W; doorCanvas.height = H; }

    function drawDoor(c: CanvasRenderingContext2D, t: number) {
      const w = W * 0.24, h = H * 0.6;
      const pulse = 1 + Math.sin(t * 2.5) * 0.03;
      if (doorAlpha < 0.01) return;
      c.save();

      // Warm glow around door
      if (doorAlpha > 0.05) {
        const g = c.createRadialGradient(W/2, H/2, 0, W/2, H/2, Math.max(w,h)*0.9);
        const a = Math.min(doorAlpha * 0.25, 0.2);
        g.addColorStop(0, `rgba(212,176,106,${a})`);
        g.addColorStop(0.3, `rgba(212,176,106,${a*0.5})`);
        g.addColorStop(1, 'rgba(212,176,106,0)');
        c.fillStyle = g; c.fillRect(0,0,W,H);
      }

      c.shadowColor = `rgba(212,176,106,${doorAlpha*0.2*pulse})`;
      c.shadowBlur = 20 * pulse;
      const openAngle = doorOpen * Math.PI / 3;
      c.translate(W/2, H/2);
      if (doorOpen > 0.01) c.scale(Math.max(0.05, Math.cos(openAngle)), 1);

      const hw = w/2, hh = h/2;
      c.fillStyle = `rgba(10,16,30,${doorAlpha*0.92})`;
      c.strokeStyle = `rgba(180,150,100,${doorAlpha*0.6})`;
      c.lineWidth = 2.5;
      const rd = 6;
      c.beginPath();
      c.moveTo(-hw+rd,-hh); c.lineTo(hw-rd,-hh);
      c.quadraticCurveTo(hw,-hh,hw,-hh+rd);
      c.lineTo(hw,hh-rd); c.quadraticCurveTo(hw,hh,hw-rd,hh);
      c.lineTo(-hw+rd,hh); c.quadraticCurveTo(-hw,hh,-hw,hh-rd);
      c.lineTo(-hw,-hh+rd); c.quadraticCurveTo(-hw,-hh,-hw+rd,-hh);
      c.closePath(); c.fill(); c.stroke();
      c.shadowBlur = 0;

      // Light leaks
      c.strokeStyle = `rgba(240,215,154,${doorAlpha*0.12})`;
      c.lineWidth = 1;
      c.beginPath(); c.moveTo(-hw+10,-hh+2); c.lineTo(hw-10,-hh+2); c.stroke();
      c.beginPath(); c.moveTo(-hw+15,hh-2); c.lineTo(hw-15,hh-2); c.stroke();
      c.beginPath(); c.moveTo(-hw+2,-hh+15); c.lineTo(-hw+2,hh-15); c.stroke();
      c.beginPath(); c.moveTo(hw-2,-hh+15); c.lineTo(hw-2,hh-15); c.stroke();

      // Vertical line
      c.strokeStyle = `rgba(180,150,100,${doorAlpha*0.3})`;
      c.lineWidth = 1;
      c.beginPath(); c.moveTo(0,-hh+8); c.lineTo(0,hh-8); c.stroke();

      // Handle
      c.save();
      c.globalAlpha = doorAlpha * 0.7;
      c.shadowColor = `rgba(240,215,154,${doorAlpha*0.21})`;
      c.shadowBlur = 8 * pulse;
      c.strokeStyle = '#D4B06A'; c.lineWidth = 2;
      c.beginPath(); c.arc(hw*0.35, 0, hw*0.045, 0, Math.PI*2); c.stroke();
      c.beginPath(); c.arc(hw*0.35, 0, hw*0.025, 0, Math.PI*2);
      c.fillStyle = `rgba(212,176,106,${doorAlpha*0.21})`; c.fill();
      c.restore();
      c.restore();
    }

    // ─── Door render loop ────────────────────────────────────
    let lastTime = 0, animFrameId = 0, isVisible = true;

    function renderDoor(ts: number) {
      if (!isVisible) return;
      const dt = Math.min((ts - lastTime) / 16, 3);
      lastTime = ts; time += dt * 0.016;
      const c = dCtx as CanvasRenderingContext2D;
      c.clearRect(0,0,W,H);
      drawDoor(c, time);
      animFrameId = requestAnimationFrame(renderDoor);
    }

    // ─── State Machine ────────────────────────────────────────
    const STATES = [
      'STORM_ALONE', 'LIGHT_APPEARS', 'CAMERA_APPROACH', 'DOOR_VISIBLE',
      'DOOR_IDLE', 'DOOR_OPENING', 'LIGHT_INVADES', 'CROSSING',
      'STORM_BEHIND', 'TAVERN_REVEAL', 'CAMERA_ADJUST', 'PAUSE_MOMENT',
      'BLOG_TRANSITION', 'TAVERN_INTERFACE', 'READY_TO_EXPLORE'
    ];

    let stateIdx = 0;
    let stateStart = 0;
    let hasInteracted = false;

    function getDur(idx: number): number {
      switch (STATES[idx]) {
        case 'STORM_ALONE': return T.stormalone;
        case 'LIGHT_APPEARS': return T.lightappears;
        case 'CAMERA_APPROACH': return T.cameraapproach;
        case 'DOOR_VISIBLE': return T.doorvisible;
        case 'DOOR_IDLE': return T.dooridle;
        case 'DOOR_OPENING': return T.dooropening;
        case 'LIGHT_INVADES': return T.lighttransition;
        case 'CROSSING': return 3000;
        case 'STORM_BEHIND': return 3000;
        case 'TAVERN_REVEAL': return T.tavernreveal;
        case 'CAMERA_ADJUST': return 3000;
        case 'PAUSE_MOMENT': return 5000;
        case 'BLOG_TRANSITION': return T.blogtransition;
        case 'TAVERN_INTERFACE': return 5000;
        case 'READY_TO_EXPLORE': return 1000;
        default: return 2000;
      }
    }

    function enterState(s: string) {
      switch (s) {
        case 'STORM_ALONE': startAudio(); break;
        case 'LIGHT_APPEARS':
          storm?.setVisibility(0.85); storm?.setIntensity(0.9); break;
        case 'CAMERA_APPROACH':
          storm?.setWind(0.7); storm?.setIntensity(0.7);
          animateDoorAlpha(0, 0.3, 2000); break;
        case 'DOOR_VISIBLE':
          storm?.setWind(0.5); storm?.setVisibility(0.7);
          animateDoorAlpha(0.3, 0.8, 1500); break;
        case 'DOOR_IDLE':
          storm?.setWind(0.3); storm?.setIntensity(0.5); storm?.setVisibility(0.6);
          animateDoorAlpha(0.8, 1, 1000);
          doorCanvas.style.pointerEvents = 'auto'; doorCanvas.style.cursor = 'pointer'; break;
        case 'DOOR_OPENING':
          storm?.setWind(0.2); storm?.setIntensity(0.3);
          animateDoorOpen(0, 1, T.dooropening);
          animateWarm(0, 0.3, T.dooropening);
          playDoorSound(); break;
        case 'LIGHT_INVADES':
          storm?.setGlobalAlpha(0.5); storm?.setIntensity(0.2);
          warmOverlay.classList.add('warm-overlay--intense');
          animateWarm(0.3, 0.7, T.lighttransition); break;
        case 'CROSSING':
          storm?.setGlobalAlpha(0.2); animateWarm(0.7, 0.9, 2000); break;
        case 'STORM_BEHIND':
          storm?.setGlobalAlpha(0.05); storm?.setIntensity(0.05); storm?.setVisibility(0.1);
          animateWarm(0.9, 1.0, 2000);
          warmOverlay.classList.add('warm-overlay--full'); break;
        case 'TAVERN_REVEAL': break;
        case 'PAUSE_MOMENT': break;
        case 'BLOG_TRANSITION': fadeOutExperience(); break;
        case 'READY_TO_EXPLORE': window.location.assign('/index'); break;
      }
    }

    function advance() {
      if (stateIdx < STATES.length - 1) {
        stateIdx++;
        stateStart = performance.now();
        enterState(STATES[stateIdx]);
      }
    }

    // ─── Animation helpers ────────────────────────────────────
    function animateDoorAlpha(from: number, to: number, dur: number) {
      const s = performance.now();
      const fn = (now: number) => {
        const p = Math.min((now - s) / dur, 1);
        doorAlpha = from + (to - from) * (1 - Math.pow(1 - p, 3));
        if (p < 1) requestAnimationFrame(fn);
      }; requestAnimationFrame(fn);
    }

    function animateDoorOpen(from: number, to: number, dur: number) {
      const s = performance.now();
      const fn = (now: number) => {
        const p = Math.min((now - s) / dur, 1);
        doorOpen = from + (to - from) * (1 - Math.pow(1 - p, 3));
        if (p < 1) requestAnimationFrame(fn);
      }; requestAnimationFrame(fn);
    }

    function animateWarm(from: number, to: number, dur: number) {
      const s = performance.now();
      const fn = (now: number) => {
        const p = Math.min((now - s) / dur, 1);
        warmAlpha = from + (to - from) * (1 - Math.pow(1 - p, 3));
        warmOverlay.style.opacity = String(warmAlpha);
        if (p < 1) requestAnimationFrame(fn);
      }; requestAnimationFrame(fn);
    }

    function fadeOutExperience() {
      root!.style.transition = 'opacity 2s ease-in-out';
      root!.style.opacity = '0';
      setTimeout(() => advance(), 2000);
    }

    // ─── Audio ──────────────────────────────────────────────
    function startAudio() {
      audio.play().catch(() => {});
    }

    function playDoorSound() {
      try {
        const Ctx = (window as any).AudioContext || (window as any).webkitAudioContext;
        if (!Ctx) return;
        let ctx = (window as any).__rnm_audio_ctx;
        if (!ctx) { ctx = new Ctx(); (window as any).__rnm_audio_ctx = ctx; }
        if (ctx.state === 'suspended') ctx.resume().catch(() => {});
        const now = ctx.currentTime;
        const osc = ctx.createOscillator(), noise = ctx.createOscillator();
        const g1 = ctx.createGain(), g2 = ctx.createGain();
        osc.type = 'sine'; osc.frequency.setValueAtTime(200,now); osc.frequency.exponentialRampToValueAtTime(120,now+1.2);
        noise.type = 'sawtooth'; noise.frequency.setValueAtTime(400,now); noise.frequency.exponentialRampToValueAtTime(600,now+0.5); noise.frequency.exponentialRampToValueAtTime(200,now+1.2);
        g1.gain.setValueAtTime(0.001,now); g1.gain.exponentialRampToValueAtTime(0.06,now+0.05); g1.gain.exponentialRampToValueAtTime(0.03,now+0.4); g1.gain.exponentialRampToValueAtTime(0.001,now+1.3);
        g2.gain.setValueAtTime(0.001,now); g2.gain.exponentialRampToValueAtTime(0.015,now+0.05); g2.gain.exponentialRampToValueAtTime(0.001,now+1.0);
        osc.connect(g1); noise.connect(g2); g1.connect(ctx.destination); g2.connect(ctx.destination);
        osc.start(now); noise.start(now); osc.stop(now+1.5); noise.stop(now+1.2);
      } catch {}
    }

    // ─── Interaction ──────────────────────────────────────────
    function handleInteraction() {
      if (hasInteracted || STATES[stateIdx] !== 'DOOR_IDLE') return;
      hasInteracted = true;
      doorCanvas.style.pointerEvents = 'none';
      advance();
    }

    // ─── Main loop: checks state durations and advances ──────
    function tick() {
      if (STATES[stateIdx] === 'READY_TO_EXPLORE') return;

      const elapsed = performance.now() - stateStart;
      const dur = getDur(stateIdx);

      // Auto-advance for all states EXCEPT DOOR_IDLE (which waits for interaction)
      if (STATES[stateIdx] !== 'DOOR_IDLE' && elapsed >= dur) {
        advance();
      }

      requestAnimationFrame(tick);
    }

    // ─── Init ──────────────────────────────────────────────────
    function init() {
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        window.location.assign('/index');
        return;
      }
      resize();
      window.addEventListener('resize', resize);
      renderDoor(performance.now());

      stateStart = performance.now();
      stateIdx = 0;
      enterState(STATES[0]);

      doorCanvas.addEventListener('click', handleInteraction);
      doorCanvas.addEventListener('touchend', handleInteraction);
      document.addEventListener('keydown', (e) => {
        if (STATES[stateIdx] === 'DOOR_IDLE' && !hasInteracted) handleInteraction();
      });

      // AFTER 3s of storm alone, auto-advance if no interaction
      setTimeout(() => {
        if (!hasInteracted && STATES[stateIdx] === 'STORM_ALONE') advance();
      }, T.stormalone);

      // Start the main tick loop for all subsequent states
      setTimeout(() => tick(), T.stormalone + 100);
    }

    window.addEventListener('beforeunload', () => cancelAnimationFrame(animFrameId));
    init();
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initializeExperience, { once: true });
  } else {
    initializeExperience();
  }
</script>
