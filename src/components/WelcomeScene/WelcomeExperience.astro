---
/**
 * WelcomeExperience — Jornada Cinematográfica da Taverna (15 Estados).
 * Seguindo o Roteiro da Animação: "Da Tempestade para a Taverna".
 * 
 * Beats do Roteiro:
 *  1. TEMPESTADE (0-3s)
 *  2. LUZ DISTANTE (3-6s)
 *  3. APROXIMAÇÃO (6-10s)
 *  4. PORTA À VISTA (10-13s)
 *  5. INTERAÇÃO (13-15s)
 *  6. PORTA COMEÇA A ABRIR (15-18s)
 *  7. LUZ INVADE A CENA (18-21s)
 *  8. TRAVESSIA (21-24s)
 *  9. TEMPESTADE FICA PARA TRÁS (24-27s)
 * 10. REVELAÇÃO DA TAVERNA (27-32s)
 * 11. CÂMERA SE AJUSTA (32-35s)
 * 12. MOMENTO DE TRANSIÇÃO (35-40s)
 * 13. TRANSIÇÃO PARA O BLOG (40-45s)
 * 14. TAVERNA SE TORNA INTERFACE (45-50s)
 * 15. PRONTO PARA EXPLORAR (50s+)
 */
import StormCanvas from './StormCanvas.astro';
import { WELCOME_CONFIG } from '../../config/welcome.config';
---

<div class="experience" id="experience-root" data-state="storm-alone"
  data-storm-alone={WELCOME_CONFIG.timing.stormAlone}
  data-light-appears={WELCOME_CONFIG.timing.lightAppears}
  data-camera-approach={WELCOME_CONFIG.timing.cameraApproach}
  data-door-visible={WELCOME_CONFIG.timing.doorVisible}
  data-door-idle={WELCOME_CONFIG.timing.doorIdle}
  data-door-opening={WELCOME_CONFIG.timing.doorOpening}
  data-light-invades={WELCOME_CONFIG.timing.lightInvades}
  data-crossing={WELCOME_CONFIG.timing.crossing}
  data-storm-behind={WELCOME_CONFIG.timing.stormBehind}
  data-tavern-reveal={WELCOME_CONFIG.timing.tavernReveal}
  data-camera-adjust={WELCOME_CONFIG.timing.cameraAdjust}
  data-pause-moment={WELCOME_CONFIG.timing.pauseMoment}
  data-blog-transition={WELCOME_CONFIG.timing.blogTransition}
  data-interface-reveal={WELCOME_CONFIG.timing.interfaceReveal}
  data-ready-to-explore={WELCOME_CONFIG.timing.readyToExplore}>

  <!-- 1. MUNDO FRIO (Montanhas, Céu Noturno e Solo de Neve) -->
  <div class="cold-world" aria-hidden="true">
    <div class="night-sky"></div>
    <div class="mountain mountain--left"></div>
    <div class="mountain mountain--right"></div>
    <div class="snow-ground"></div>
  </div>

  <!-- 2. MUNDO DA TAVERNA (Interior Aquecido) -->
  <div class="tavern-world" aria-hidden="true">
    <div class="beam beam--left"></div>
    <div class="beam beam--right"></div>
    <div class="shelf shelf--left"></div>
    <div class="shelf shelf--right"></div>
    <div class="hearth">
      <span class="flame-1"></span>
      <span class="flame-2"></span>
      <span class="flame-3"></span>
    </div>
    <div class="table"></div>
    <div class="dust"></div>
  </div>

  <!-- 3. CÂMERA E ARCO DE PEDRA DA PORTA -->
  <div class="camera" id="camera">
    <!-- Ponto de luz distante na tempestade -->
    <div class="beacon" aria-hidden="true"></div>

    <!-- Portal de Pedra -->
    <div class="stone-arch" aria-hidden="true">
      <div class="arch-crown"></div>
      <div class="pillar pillar--left"></div>
      <div class="pillar pillar--right"></div>
      <div class="doorway-light"></div>
    </div>

    <!-- A Porta Rúnica Interativa -->
    <button class="door" id="door" type="button" aria-label="Abrir a porta da taverna e entrar" disabled>
      <span class="door-leaf door-leaf--left">
        <span class="planks"></span>
        <span class="iron iron--top"></span>
        <span class="iron iron--bottom"></span>
        <span class="rune">ᚱ</span>
        <span class="ring ring--left"></span>
      </span>
      <span class="door-leaf door-leaf--right">
        <span class="planks"></span>
        <span class="iron iron--top"></span>
        <span class="iron iron--bottom"></span>
        <span class="rune">ᛗ</span>
        <span class="ring ring--right"></span>
      </span>
    </button>
  </div>

  <!-- 4. TEMPESTADE (Canvas de Partículas) -->
  <StormCanvas
    far={WELCOME_CONFIG.snow.far}
    mid={WELCOME_CONFIG.snow.mid}
    near={WELCOME_CONFIG.snow.near}
    gusts={WELCOME_CONFIG.snow.gusts}
    blur={WELCOME_CONFIG.snow.blur}
    fog={WELCOME_CONFIG.snow.fog}
  />

  <!-- 5. EFEITOS ATMOSFÉRICOS E TEXTOS NARRATIVOS -->
  <div class="threshold-flare" aria-hidden="true"></div>
  <div class="frost" aria-hidden="true"></div>
  <div class="vignette" aria-hidden="true"></div>
  
  <p class="door-prompt" id="door-prompt" aria-live="polite">Clique para abrir a porta</p>
  <p class="arrival-copy" id="arrival-copy" aria-hidden="true">Você encontrou o refúgio.</p>

  <!-- 6. CONTROLES DE INTERFACE (Som e Skip) -->
  <div class="controls">
    <button class="skip" id="skip-intro" type="button">Pular introdução</button>
    <button class="sound" id="sound-toggle" type="button" aria-pressed="false" aria-label="Ativar som ambiente da taverna">
      <span class="sound-icon" aria-hidden="true"></span>
      <span class="sound-label">Som</span>
    </button>
  </div>

  <!-- Audio Ambiente -->
  <audio id="ambient-audio" loop preload="none">
    <source src={WELCOME_CONFIG.audio.src} type="audio/mp4" />
  </audio>
</div>

<style>
  :global(html), :global(body) {
    width: 100%;
    height: 100%;
    overflow: hidden;
    margin: 0;
    padding: 0;
  }

  .experience {
    --cold: #060B17;
    --ember: #d58a34;
    --gold: #D4B06A;
    position: fixed;
    inset: 0;
    isolation: isolate;
    overflow: hidden;
    color: #eadbc5;
    background: var(--cold);
    font-family: 'Cinzel', Georgia, serif;
    user-select: none;
    z-index: 9999;
  }

  .cold-world, .tavern-world, .frost, .vignette, .threshold-flare {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  /* Beat 1-4: Cold World Base */
  .cold-world {
    z-index: 0;
    transition: opacity 3s ease, filter 3s ease;
  }

  .night-sky {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 50% 44%, rgba(102, 127, 145, 0.22), transparent 27%),
                linear-gradient(175deg, #02060b 0%, #0b1723 52%, #17242d);
  }
  .night-sky::after {
    content: '';
    position: absolute;
    inset: -8%;
    background: repeating-radial-gradient(ellipse at 50% 65%, transparent 0 8%, rgba(173, 192, 202, 0.025) 8.4% 8.8%);
    animation: cloud-drift 12s ease-in-out infinite alternate;
  }

  .mountain {
    position: absolute;
    bottom: 12%;
    width: 65%;
    height: 72%;
    background: linear-gradient(135deg, #07101a, #111d27 55%, #050b11);
    filter: drop-shadow(0 -12px 28px rgba(0,0,0,0.65));
  }
  .mountain--left { left: -24%; clip-path: polygon(0 100%, 14% 51%, 27% 62%, 46% 28%, 58% 51%, 75% 39%, 100% 100%); }
  .mountain--right { right: -22%; clip-path: polygon(0 100%, 17% 49%, 34% 58%, 53% 18%, 66% 51%, 81% 39%, 100% 100%); }

  .snow-ground {
    position: absolute;
    inset: 68% -10% -18%;
    background: radial-gradient(ellipse at 50% 0%, #303e48, #131e27 35%, #050b11 72%);
    transform: perspective(500px) rotateX(54deg);
    transform-origin: top;
  }

  /* Camera Container & Dynamic Sway */
  .camera {
    position: absolute;
    inset: 0;
    z-index: 5;
    transform: scale(0.38);
    opacity: 0;
    transition: transform 4s cubic-bezier(0.2, 0.72, 0.2, 1), opacity 2.2s ease;
    animation: camera-sway 5s ease-in-out infinite;
    will-change: transform, opacity;
  }

  /* Beat 2: Beacon of Light */
  .beacon {
    position: absolute;
    left: 50%;
    top: 50%;
    width: 10vmin;
    aspect-ratio: 0.55;
    transform: translate(-50%, -50%);
    border-radius: 50%;
    background: #ed9c3f;
    box-shadow: 0 0 24px 10px rgba(237, 156, 63, 0.7), 0 0 100px 40px rgba(213, 110, 30, 0.25);
    opacity: 0;
    transition: opacity 2.5s ease, transform 4s ease;
  }

  /* Beat 3-4: Stone Arch */
  .stone-arch {
    position: absolute;
    left: 50%;
    top: 50%;
    width: clamp(230px, 31vw, 480px);
    height: min(82vh, 720px);
    transform: translate(-50%, -50%);
    opacity: 0;
    filter: drop-shadow(0 22px 28px rgba(0,0,0,0.85));
    transition: opacity 2.2s ease;
  }
  .arch-crown {
    position: absolute;
    inset: 0 0 auto;
    height: 34%;
    border: clamp(28px, 3.6vw, 54px) solid #1b2021;
    border-bottom: 0;
    border-radius: 50% 50% 0 0;
    background: repeating-conic-gradient(from 260deg at 50% 100%, #2c302e 0 8deg, #151a1a 8deg 10deg, #343633 10deg 18deg);
    box-shadow: inset 0 0 24px #060808;
  }
  .pillar {
    position: absolute;
    top: 27%;
    bottom: -4%;
    width: 18%;
    background: repeating-linear-gradient(0deg, #191d1c 0 11%, #333532 11.5% 21%, #111514 21.5% 23%);
    box-shadow: inset 8px 0 12px rgba(255,255,255,0.035), inset -9px 0 14px #060808;
  }
  .pillar--left { left: 0; }
  .pillar--right { right: 0; }

  .doorway-light {
    position: absolute;
    inset: 12% 17% 0;
    border-radius: 46% 46% 2% 2%;
    background: radial-gradient(ellipse at 50% 45%, #ffe0a0, #d77824 42%, #351406 82%);
    box-shadow: 0 0 55px rgba(225, 126, 37, 0.55);
  }

  /* Beat 4-6: Door Component */
  .door {
    position: absolute;
    left: 50%;
    top: 50%;
    width: clamp(170px, 22vw, 342px);
    height: min(65vh, 570px);
    padding: 0;
    border: 0;
    outline: 0;
    background: transparent;
    transform: translate(-50%, -43%);
    perspective: 1100px;
    cursor: default;
  }

  .door-leaf {
    position: absolute;
    top: 0;
    width: 50.5%;
    height: 100%;
    overflow: hidden;
    background: linear-gradient(90deg, #211008, #4b2612 35%, #32170c 73%, #160a06);
    border: 2px solid #0c0705;
    box-shadow: inset 0 0 38px #080403, 0 0 0 1px rgba(153,91,42,0.35);
    transition: transform 3s cubic-bezier(0.55, 0.05, 0.18, 1), filter 0.45s ease, box-shadow 0.45s ease;
    backface-visibility: hidden;
    will-change: transform;
  }
  .door-leaf--left { left: 0; transform-origin: left; border-radius: 48% 0 0 2% / 11% 0 0 1%; }
  .door-leaf--right { right: 0; transform-origin: right; border-radius: 0 48% 2% 0 / 0 11% 1% 0; }

  .planks {
    position: absolute;
    inset: 0;
    opacity: 0.58;
    background: repeating-linear-gradient(90deg, transparent 0 30%, rgba(6,3,2,0.8) 30.5% 32%, rgba(116,61,26,0.25) 33% 34%);
  }
  .iron {
    position: absolute;
    left: 5%;
    right: 5%;
    height: 5%;
    border: 1px solid #050505;
    background: linear-gradient(#373a37, #0b0d0d 45%, #242623);
    box-shadow: 0 3px 7px #090403;
  }
  .iron--top { top: 29%; }
  .iron--bottom { bottom: 23%; }

  .rune {
    position: absolute;
    top: 43%;
    left: 50%;
    transform: translate(-50%, -50%);
    color: #D4B06A;
    font-size: clamp(20px, 3vw, 42px);
    text-shadow: 0 0 12px rgba(212, 176, 106, 0.5);
    opacity: 0.6;
    transition: opacity 0.4s, text-shadow 0.4s;
  }

  .ring {
    position: absolute;
    top: 54%;
    width: clamp(18px, 2.3vw, 35px);
    aspect-ratio: 1;
    border: clamp(3px, 0.25vw, 5px) solid #161817;
    border-radius: 50%;
    box-shadow: inset 0 0 0 1px #5b5141, 0 4px 5px #070302;
    transition: transform 0.4s ease;
  }
  .ring--left { right: 8%; }
  .ring--right { left: 8%; }

  /* Atmosphere Layers */
  .frost {
    z-index: 9;
    background: radial-gradient(ellipse, transparent 30%, rgba(135, 163, 178, 0.12) 67%, rgba(203, 220, 226, 0.18));
    mix-blend-mode: screen;
    transition: opacity 3s;
  }
  .vignette {
    z-index: 12;
    background: radial-gradient(ellipse, transparent 37%, rgba(0, 3, 6, 0.43) 76%, rgba(0, 2, 4, 0.88));
    transition: opacity 3s;
  }
  .threshold-flare {
    z-index: 10;
    opacity: 0;
    background: radial-gradient(ellipse, rgba(255, 241, 190, 0.98), rgba(229, 154, 66, 0.7) 28%, transparent 66%);
    transform: scale(0.2);
    transition: opacity 3s, transform 3s cubic-bezier(0.2, 0.8, 0.2, 1);
  }

  /* Narrative Typography */
  .door-prompt, .arrival-copy {
    position: absolute;
    z-index: 15;
    left: 50%;
    margin: 0;
    text-align: center;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    text-shadow: 0 2px 12px #000;
    opacity: 0;
    transition: opacity 1.2s ease, transform 1.2s ease;
    pointer-events: none;
  }
  .door-prompt {
    bottom: 8%;
    transform: translate(-50%, 10px);
    color: rgba(239, 216, 177, 0.85);
    font-size: clamp(0.72rem, 1.2vw, 0.9rem);
  }
  .arrival-copy {
    top: 15%;
    transform: translate(-50%, 14px);
    color: #F0D79A;
    font-size: clamp(0.9rem, 1.5vw, 1.25rem);
    text-shadow: 0 0 20px rgba(212, 176, 106, 0.5);
  }

  /* Controls UI */
  .controls {
    position: absolute;
    z-index: 30;
    inset: auto clamp(16px, 3vw, 42px) clamp(16px, 3vw, 32px);
    display: flex;
    align-items: center;
    justify-content: space-between;
    pointer-events: none;
  }
  .skip, .sound {
    pointer-events: auto;
    border: 0;
    color: rgba(229, 221, 207, 0.7);
    background: rgba(3, 7, 10, 0.4);
    font: 500 0.7rem/1 'Cinzel', Georgia, serif;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    cursor: pointer;
    backdrop-filter: blur(8px);
    border-radius: 4px;
    transition: all 0.3s ease;
  }
  .skip {
    padding: 0.6rem 1rem;
    background: rgba(10, 16, 38, 0.5);
    border: 1px solid rgba(212, 176, 106, 0.2);
  }
  .sound {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.6rem 1rem;
    border: 1px solid rgba(212, 176, 106, 0.2);
  }
  .skip:hover, .sound:hover {
    color: #F0D79A;
    border-color: #D4B06A;
    box-shadow: 0 0 12px rgba(212, 176, 106, 0.3);
  }
  .sound-icon {
    width: 12px;
    height: 12px;
    border-left: 5px solid currentColor;
    border-top: 4px solid transparent;
    border-bottom: 4px solid transparent;
    position: relative;
  }
  .sound-icon::after {
    content: '';
    position: absolute;
    left: 3px;
    top: -5px;
    width: 7px;
    height: 8px;
    border-right: 1px solid;
    border-radius: 50%;
    opacity: 0.25;
  }
  .sound[aria-pressed="true"] .sound-icon::after { opacity: 1; }

  /* Beat 10+: Tavern Interior */
  .tavern-world {
    z-index: 2;
    opacity: 0;
    overflow: hidden;
    transform: scale(1.08);
    background: radial-gradient(circle at 50% 48%, #6c3315, #26150d 31%, #100b08 72%);
    transition: opacity 4s ease, transform 5s cubic-bezier(0.2, 0.75, 0.25, 1), filter 3s ease;
  }
  .tavern-world::before {
    content: '';
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(0deg, transparent 0 14%, rgba(0,0,0,0.16) 14.5% 15%),
                linear-gradient(90deg, rgba(0,0,0,0.64), transparent 28% 72%, rgba(0,0,0,0.64));
  }
  .beam {
    position: absolute;
    top: -12%;
    width: 9%;
    height: 125%;
    background: linear-gradient(90deg, #120a06, #4b2816, #170b07);
    box-shadow: 0 0 25px #080403;
  }
  .beam--left { left: 18%; transform: rotate(-3deg); }
  .beam--right { right: 18%; transform: rotate(3deg); }

  .shelf {
    position: absolute;
    top: 28%;
    width: 23%;
    height: 36%;
    border-block: 12px solid #351c10;
    background: repeating-linear-gradient(90deg, #18130e 0 8%, #7e4b26 8.5% 11%, #27180f 11.5% 16%);
    box-shadow: 0 10px 22px #080403;
  }
  .shelf--left { left: 2%; }
  .shelf--right { right: 2%; }

  .hearth {
    position: absolute;
    left: 50%;
    top: 36%;
    width: min(23vw, 270px);
    height: min(34vh, 290px);
    transform: translateX(-50%);
    border: clamp(16px, 2vw, 28px) solid #30251e;
    border-radius: 44% 44% 0 0;
    background: radial-gradient(ellipse at 50% 90%, #fff1a3 0 5%, #ef8a2d 18%, #a13712 38%, #100704 63%);
    box-shadow: 0 0 80px rgba(225, 104, 27, 0.45), inset 0 0 30px #000;
  }
  .hearth span {
    position: absolute;
    bottom: 8%;
    width: 16%;
    height: 46%;
    border-radius: 50%;
    background: linear-gradient(#ffe9a4, #f18a25 50%, transparent);
    transform-origin: bottom;
    animation: flame 1.3s ease-in-out infinite alternate;
  }
  .flame-1 { left: 45%; }
  .flame-2 { left: 27%; height: 31% !important; animation-delay: -0.6s; }
  .flame-3 { left: 61%; height: 36% !important; animation-delay: -0.9s; }

  .table {
    position: absolute;
    left: 50%;
    bottom: -10%;
    width: min(72vw, 960px);
    height: 34%;
    transform: translateX(-50%) perspective(500px) rotateX(58deg);
    background: repeating-linear-gradient(90deg, #2a1309 0 17%, #4f2712 17.5% 32%, #211006 32.5% 34%);
    border: 8px solid #160b06;
    box-shadow: 0 -16px 40px #090403;
  }
  .dust {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(circle, #efc57d 0 1px, transparent 1.5px);
    background-size: 91px 73px;
    opacity: 0.14;
    animation: dust-rise 9s linear infinite;
  }

  /* Frame de Preview do Site */
  :global(.site-preview) {
    position: absolute;
    z-index: 22;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
    background: #0a1026;
    opacity: 0;
    transform: scale(1.035);
    pointer-events: none;
    transition: opacity 4s ease, transform 4s cubic-bezier(0.2, 0.75, 0.2, 1);
  }

  /* STATE MACHINE ANIMATION STYLES FOR THE 15 BEATS */
  [data-state="light-appears"] .beacon { opacity: 0.7; }

  [data-state="camera-approach"] .camera { opacity: 0.75; transform: scale(0.72); }
  [data-state="camera-approach"] .beacon { opacity: 1; transform: translate(-50%, -50%) scale(1.4); }

  [data-state="door-visible"] .camera,
  [data-state="door-idle"] .camera,
  [data-state="door-opening"] .camera,
  [data-state="light-invades"] .camera { opacity: 1; transform: scale(1); }

  [data-state="door-visible"] .stone-arch,
  [data-state="door-idle"] .stone-arch,
  [data-state="door-opening"] .stone-arch,
  [data-state="light-invades"] .stone-arch { opacity: 1; }

  [data-state="door-idle"] .door { cursor: pointer; }
  [data-state="door-idle"] .door-prompt { opacity: 1; transform: translate(-50%, 0); }
  [data-state="door-idle"] .door:hover .door-leaf,
  [data-state="door-idle"] .door:focus-visible .door-leaf {
    filter: brightness(1.25);
    box-shadow: inset 0 0 38px #080403, 0 0 30px rgba(235, 151, 60, 0.4);
  }
  [data-state="door-idle"] .door:hover .rune { opacity: 1; text-shadow: 0 0 20px #F0D79A; }
  [data-state="door-idle"] .door:hover .ring { transform: rotate(-12deg); }

  [data-state="door-opening"] .door-prompt { opacity: 0; }
  [data-state="door-opening"] .door-leaf--left,
  [data-state="light-invades"] .door-leaf--left,
  [data-state="crossing"] .door-leaf--left,
  [data-state="storm-behind"] .door-leaf--left { transform: rotateY(-84deg); }

  [data-state="door-opening"] .door-leaf--right,
  [data-state="light-invades"] .door-leaf--right,
  [data-state="crossing"] .door-leaf--right,
  [data-state="storm-behind"] .door-leaf--right { transform: rotateY(84deg); }

  [data-state="light-invades"] .threshold-flare { opacity: 0.8; transform: scale(0.8); }

  [data-state="crossing"] .threshold-flare { opacity: 1; transform: scale(1.8); }
  [data-state="crossing"] .camera { transform: scale(2.4); opacity: 0.15; transition: transform 3s cubic-bezier(0.2, 0.75, 0.2, 1), opacity 2.7s; }

  [data-state="storm-behind"] .cold-world,
  [data-state="storm-behind"] .camera,
  [data-state="tavern-reveal"] .cold-world,
  [data-state="tavern-reveal"] .camera { opacity: 0; }

  [data-state="storm-behind"] .tavern-world,
  [data-state="tavern-reveal"] .tavern-world,
  [data-state="camera-adjust"] .tavern-world,
  [data-state="pause-moment"] .tavern-world,
  [data-state="blog-transition"] .tavern-world,
  [data-state="interface-reveal"] .tavern-world { opacity: 1; transform: scale(1); }

  [data-state="storm-behind"] .threshold-flare { opacity: 0.5; transform: scale(2.1); }

  [data-state="tavern-reveal"] .threshold-flare,
  [data-state="camera-adjust"] .threshold-flare,
  [data-state="pause-moment"] .threshold-flare { opacity: 0; transform: scale(2.4); }

  [data-state="tavern-reveal"] .frost,
  [data-state="camera-adjust"] .frost,
  [data-state="pause-moment"] .frost { opacity: 0; }

  [data-state="camera-adjust"] .tavern-world { filter: brightness(1.12) saturate(1.08); }

  [data-state="pause-moment"] .arrival-copy { opacity: 1; transform: translate(-50%, 0); }
  [data-state="blog-transition"] .arrival-copy { opacity: 0; }

  [data-state="interface-reveal"] :global(.site-preview) { opacity: 1; transform: scale(1); }

  @keyframes camera-sway {
    0%, 100% { transform: translate(-4px, 2px); }
    50% { transform: translate(5px, -3px); }
  }
  @keyframes cloud-drift { to { transform: translate3d(3%, -2%, 0) scale(1.04); } }
  @keyframes flame { from { transform: scaleX(0.8) rotate(-4deg); } to { transform: scaleX(1.15) rotate(5deg); } }
  @keyframes dust-rise { to { background-position: 18px -73px; } }

  @media (max-width: 640px) {
    .camera { transform: scale(0.32); }
    .stone-arch { width: min(78vw, 340px); height: 72vh; }
    .door { width: min(57vw, 250px); height: 55vh; transform: translate(-50%, -40%); }
    .mountain { width: 86%; }
    .door-prompt { bottom: 10%; width: 100%; }
  }

  @media (prefers-reduced-motion: reduce) {
    .night-sky::after, .camera, .hearth span, .dust { animation: none !important; }
    .experience * { transition-duration: 0.3s !important; }
  }
</style>

<script>
  import { setWelcomeSeenCookie, shouldSkipWelcome } from '../../lib/welcome';

  const initializeExperience = () => {
    const root = document.getElementById('experience-root') as HTMLElement | null;
    const door = document.getElementById('door') as HTMLButtonElement | null;
    const skip = document.getElementById('skip-intro') as HTMLButtonElement | null;
    const sound = document.getElementById('sound-toggle') as HTMLButtonElement | null;
    const audio = document.getElementById('ambient-audio') as HTMLAudioElement | null;

    if (!root || !door || !skip || !sound || !audio) return;

    const replay = new URLSearchParams(location.search).has('replay');
    const hasSeen = shouldSkipWelcome();

    if (hasSeen && !replay) {
      location.replace('/index');
      return;
    }

    const reduced = matchMedia('(prefers-reduced-motion: reduce)').matches;
    const storm = (window as any).__rnm_storm;
    const duration = (key: string) => Number(root.dataset[key] || 3000);
    const wait = (ms: number) => new Promise<void>(resolve => setTimeout(resolve, reduced ? Math.min(ms, 150) : ms));

    let complete = false;

    // 15 States Transition Logic
    const state = (name: string) => {
      root.dataset.state = name;

      switch (name) {
        case 'light-appears':
          storm?.setVisibility(0.82);
          break;
        case 'camera-approach':
          storm?.setWind(0.86);
          storm?.setIntensity(0.9);
          break;
        case 'door-visible':
          storm?.setWind(0.72);
          storm?.setVisibility(0.7);
          break;
        case 'door-idle':
          storm?.setWind(0.58);
          storm?.setIntensity(0.75);
          break;
        case 'door-opening':
          storm?.setWind(0.42);
          storm?.setIntensity(0.6);
          playDoorCreakSound();
          break;
        case 'light-invades':
          storm?.setGlobalAlpha(0.72);
          storm?.setIntensity(0.45);
          break;
        case 'crossing':
          storm?.setGlobalAlpha(0.3);
          storm?.setIntensity(0.22);
          break;
        case 'storm-behind':
          storm?.setGlobalAlpha(0.05);
          storm?.setIntensity(0.04);
          storm?.setVisibility(0.05);
          break;
      }
    };

    const playDoorCreakSound = () => {
      try {
        const Ctx = (window as any).AudioContext || (window as any).webkitAudioContext;
        if (!Ctx) return;
        let ctx = (window as any).__rnm_audio_ctx;
        if (!ctx) { ctx = new Ctx(); (window as any).__rnm_audio_ctx = ctx; }
        if (ctx.state === 'suspended') ctx.resume().catch(() => {});
        const now = ctx.currentTime;
        const osc = ctx.createOscillator();
        const gain = ctx.createGain();
        osc.type = 'sine';
        osc.frequency.setValueAtTime(180, now);
        osc.frequency.exponentialRampToValueAtTime(110, now + 1.4);
        gain.gain.setValueAtTime(0.001, now);
        gain.gain.exponentialRampToValueAtTime(0.05, now + 0.1);
        gain.gain.exponentialRampToValueAtTime(0.001, now + 1.5);
        osc.connect(gain);
        gain.connect(ctx.destination);
        osc.start(now);
        osc.stop(now + 1.6);
      } catch {}
    };

    const finish = () => {
      if (complete) return;
      complete = true;
      setWelcomeSeenCookie();
      localStorage.setItem('rnm_welcome_completed', String(Date.now()));
      location.replace('/index');
    };

    const preview = () => {
      if (root.querySelector('.site-preview')) return;
      const frame = document.createElement('iframe');
      frame.className = 'site-preview';
      frame.src = '/index';
      frame.title = 'Página inicial do Runas na Mesa';
      frame.tabIndex = -1;
      frame.setAttribute('aria-hidden', 'true');
      root.append(frame);
    };

    const waitForDoorClick = () => new Promise<void>(resolve => {
      const handleOpen = () => {
        door.disabled = true;
        resolve();
      };
      door.addEventListener('click', handleOpen, { once: true });
    });

    const runSequence = async () => {
      if (reduced) {
        state('tavern-reveal');
        await wait(300);
        finish();
        return;
      }

      // Beat 1: STORM_ALONE (0 - 3s)
      state('storm-alone');
      await wait(duration('stormAlone'));

      // Beat 2: LIGHT_APPEARS (3 - 6s)
      state('light-appears');
      await wait(duration('lightAppears'));

      // Beat 3: CAMERA_APPROACH (6 - 10s)
      state('camera-approach');
      await wait(duration('cameraApproach'));

      // Beat 4: DOOR_VISIBLE (10 - 13s)
      state('door-visible');
      await wait(duration('doorVisible'));

      // Beat 5: INTERACTION / DOOR_IDLE (13 - 15s)
      state('door-idle');
      door.disabled = false;
      await waitForDoorClick();

      // Beat 6: DOOR_OPENING (15 - 18s)
      state('door-opening');
      await wait(duration('doorOpening'));

      // Beat 7: LIGHT_INVADES (18 - 21s)
      state('light-invades');
      await wait(duration('lightInvades'));

      // Beat 8: CROSSING (21 - 24s)
      state('crossing');
      await wait(duration('crossing'));

      // Beat 9: STORM_BEHIND (24 - 27s)
      state('storm-behind');
      await wait(duration('stormBehind'));

      // Beat 10: TAVERN_REVEAL (27 - 32s)
      state('tavern-reveal');
      await wait(duration('tavernReveal'));

      // Beat 11: CAMERA_ADJUST (32 - 35s)
      state('camera-adjust');
      await wait(duration('cameraAdjust'));

      // Beat 12: PAUSE_MOMENT (35 - 40s)
      state('pause-moment');
      await wait(duration('pauseMoment'));

      // Beat 13: BLOG_TRANSITION (40 - 45s)
      preview();
      state('blog-transition');
      await wait(duration('blogTransition'));

      // Beat 14: INTERFACE_REVEAL (45 - 50s)
      state('interface-reveal');
      await wait(duration('interfaceReveal'));

      // Beat 15: READY_TO_EXPLORE (50s+)
      finish();
    };

    // Sound Controls
    sound.addEventListener('click', () => {
      const enabled = sound.getAttribute('aria-pressed') !== 'true';
      sound.setAttribute('aria-pressed', String(enabled));
      sound.setAttribute('aria-label', enabled ? 'Desativar som ambiente da taverna' : 'Ativar som ambiente da taverna');
      audio.volume = 0.3;
      if (enabled) {
        audio.play().catch(() => sound.setAttribute('aria-pressed', 'false'));
      } else {
        audio.pause();
      }
    });

    skip.addEventListener('click', finish);

    runSequence();
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initializeExperience, { once: true });
  } else {
    initializeExperience();
  }
</script>
