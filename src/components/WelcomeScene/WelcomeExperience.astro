---
import StormCanvas from './StormCanvas.astro';
import { WELCOME_CONFIG } from '../../config/welcome.config';
---

<div class="experience" id="experience-root" data-state="storm-alone"
  data-storm-alone={WELCOME_CONFIG.timing.stormAlone}
  data-light-appears={WELCOME_CONFIG.timing.lightAppears}
  data-camera-approach={WELCOME_CONFIG.timing.cameraApproach}
  data-door-visible={WELCOME_CONFIG.timing.doorVisible}
  data-door-opening={WELCOME_CONFIG.timing.doorOpening}
  data-light-transition={WELCOME_CONFIG.timing.lightTransition}
  data-crossing={WELCOME_CONFIG.timing.crossing}
  data-storm-behind={WELCOME_CONFIG.timing.stormBehind}
  data-tavern-reveal={WELCOME_CONFIG.timing.tavernReveal}
  data-camera-adjust={WELCOME_CONFIG.timing.cameraAdjust}
  data-pause-moment={WELCOME_CONFIG.timing.pauseMoment}
  data-blog-transition={WELCOME_CONFIG.timing.blogTransition}
  data-interface-reveal={WELCOME_CONFIG.timing.interfaceReveal}>

  <div class="cold-world" aria-hidden="true">
    <div class="night-sky"></div>
    <div class="mountain mountain--left"></div>
    <div class="mountain mountain--right"></div>
    <div class="snow-ground"></div>
  </div>

  <div class="tavern-world" aria-hidden="true">
    <div class="beam beam--left"></div><div class="beam beam--right"></div>
    <div class="shelf shelf--left"></div><div class="shelf shelf--right"></div>
    <div class="hearth"><span></span><span></span><span></span></div>
    <div class="table"></div><div class="dust"></div>
  </div>

  <div class="camera">
    <div class="beacon" aria-hidden="true"></div>
    <div class="stone-arch" aria-hidden="true">
      <div class="arch-crown"></div>
      <div class="pillar pillar--left"></div><div class="pillar pillar--right"></div>
      <div class="doorway-light"></div>
    </div>
    <button class="door" id="door" type="button" aria-label="Abrir a porta da taverna" disabled>
      <span class="door-leaf door-leaf--left">
        <span class="planks"></span><span class="iron iron--top"></span><span class="iron iron--bottom"></span>
        <span class="rune">ᚱ</span><span class="ring ring--left"></span>
      </span>
      <span class="door-leaf door-leaf--right">
        <span class="planks"></span><span class="iron iron--top"></span><span class="iron iron--bottom"></span>
        <span class="rune">ᛗ</span><span class="ring ring--right"></span>
      </span>
    </button>
  </div>

  <StormCanvas far={WELCOME_CONFIG.snow.far} mid={WELCOME_CONFIG.snow.mid}
    near={WELCOME_CONFIG.snow.near} gusts={WELCOME_CONFIG.snow.gusts}
    blur={WELCOME_CONFIG.snow.blur} fog={WELCOME_CONFIG.snow.fog} />

  <div class="threshold-flare" aria-hidden="true"></div>
  <div class="frost" aria-hidden="true"></div><div class="vignette" aria-hidden="true"></div>
  <p class="door-prompt" aria-live="polite">A porta espera por você</p>
  <p class="arrival-copy" aria-hidden="true">Você chegou.</p>

  <div class="controls">
    <button class="skip" id="skip-intro" type="button" hidden>Pular a travessia</button>
    <button class="sound" id="sound-toggle" type="button" aria-pressed="false" aria-label="Ativar som ambiente">
      <span class="sound-icon" aria-hidden="true"></span><span>Som</span>
    </button>
  </div>
  <audio id="ambient-audio" loop preload="none"><source src={WELCOME_CONFIG.audio.src} type="audio/mp4" /></audio>
</div>

<style>
  :global(html), :global(body) { width: 100%; height: 100%; overflow: hidden; }
  .experience { --cold:#07101b; --ember:#d58a34; position:fixed; inset:0; isolation:isolate; overflow:hidden; color:#eadbc5; background:var(--cold); font-family:Georgia,'Times New Roman',serif; }
  .cold-world,.tavern-world,.frost,.vignette,.threshold-flare { position:absolute; inset:0; pointer-events:none; }
  .cold-world { z-index:0; transition:opacity 3s ease,filter 3s ease; }
  .night-sky { position:absolute; inset:0; background:radial-gradient(ellipse at 50% 44%,rgba(102,127,145,.22),transparent 27%),linear-gradient(175deg,#02060b 0%,#0b1723 52%,#17242d); }
  .night-sky::after { content:''; position:absolute; inset:-8%; background:repeating-radial-gradient(ellipse at 50% 65%,transparent 0 8%,rgba(173,192,202,.025) 8.4% 8.8%); animation:cloud-drift 9s ease-in-out infinite alternate; }
  .mountain { position:absolute; bottom:12%; width:65%; height:72%; background:linear-gradient(135deg,#07101a,#111d27 55%,#050b11); filter:drop-shadow(0 -12px 28px rgba(0,0,0,.65)); }
  .mountain--left { left:-24%; clip-path:polygon(0 100%,14% 51%,27% 62%,46% 28%,58% 51%,75% 39%,100% 100%); }
  .mountain--right { right:-22%; clip-path:polygon(0 100%,17% 49%,34% 58%,53% 18%,66% 51%,81% 39%,100% 100%); }
  .snow-ground { position:absolute; inset:68% -10% -18%; background:radial-gradient(ellipse at 50% 0%,#303e48,#131e27 35%,#050b11 72%); transform:perspective(500px) rotateX(54deg); transform-origin:top; }

  .camera { position:absolute; inset:0; z-index:5; transform:scale(.42); opacity:0; transition:transform 4s cubic-bezier(.2,.72,.2,1),opacity 2.2s ease; animation:camera-sway 4.8s ease-in-out infinite; }
  .beacon { position:absolute; left:50%; top:50%; width:9vmin; aspect-ratio:.55; transform:translate(-50%,-50%); border-radius:50%; background:#ed9c3f; box-shadow:0 0 18px 7px rgba(237,156,63,.65),0 0 80px 30px rgba(213,110,30,.2); opacity:0; transition:opacity 2.5s ease,transform 4s ease; }
  .stone-arch { position:absolute; left:50%; top:50%; width:clamp(230px,31vw,480px); height:min(82vh,720px); transform:translate(-50%,-50%); opacity:0; filter:drop-shadow(0 22px 28px rgba(0,0,0,.85)); transition:opacity 2s ease; }
  .arch-crown { position:absolute; inset:0 0 auto; height:34%; border:clamp(28px,3.6vw,54px) solid #1b2021; border-bottom:0; border-radius:50% 50% 0 0; background:repeating-conic-gradient(from 260deg at 50% 100%,#2c302e 0 8deg,#151a1a 8deg 10deg,#343633 10deg 18deg); box-shadow:inset 0 0 24px #060808; }
  .pillar { position:absolute; top:27%; bottom:-4%; width:18%; background:repeating-linear-gradient(0deg,#191d1c 0 11%,#333532 11.5% 21%,#111514 21.5% 23%); box-shadow:inset 8px 0 12px rgba(255,255,255,.035),inset -9px 0 14px #060808; }
  .pillar--left{left:0}.pillar--right{right:0}
  .doorway-light { position:absolute; inset:12% 17% 0; border-radius:46% 46% 2% 2%; background:radial-gradient(ellipse at 50% 45%,#ffe0a0,#d77824 42%,#351406 82%); box-shadow:0 0 55px rgba(225,126,37,.55); }

  .door { position:absolute; left:50%; top:50%; width:clamp(170px,22vw,342px); height:min(65vh,570px); padding:0; border:0; outline:0; background:transparent; transform:translate(-50%,-43%); perspective:1100px; cursor:default; }
  .door-leaf { position:absolute; top:0; width:50.5%; height:100%; overflow:hidden; background:linear-gradient(90deg,#211008,#4b2612 35%,#32170c 73%,#160a06); border:2px solid #0c0705; box-shadow:inset 0 0 38px #080403,0 0 0 1px rgba(153,91,42,.35); transition:transform 3s cubic-bezier(.55,.05,.18,1),filter .45s ease,box-shadow .45s ease; backface-visibility:hidden; }
  .door-leaf--left { left:0; transform-origin:left; border-radius:48% 0 0 2%/11% 0 0 1%; }
  .door-leaf--right { right:0; transform-origin:right; border-radius:0 48% 2% 0/0 11% 1% 0; }
  .planks { position:absolute; inset:0; opacity:.58; background:repeating-linear-gradient(90deg,transparent 0 30%,rgba(6,3,2,.8) 30.5% 32%,rgba(116,61,26,.25) 33% 34%); }
  .iron { position:absolute; left:5%; right:5%; height:5%; border:1px solid #050505; background:linear-gradient(#373a37,#0b0d0d 45%,#242623); box-shadow:0 3px 7px #090403; }
  .iron::before,.iron::after { content:''; position:absolute; top:50%; width:7px; aspect-ratio:1; border-radius:50%; background:#020303; box-shadow:inset 1px 1px #555; transform:translateY(-50%); }
  .iron::before{left:8%}.iron::after{right:8%}.iron--top{top:29%}.iron--bottom{bottom:23%}
  .rune { position:absolute; top:43%; left:50%; transform:translate(-50%,-50%); color:#9d6936; font-size:clamp(20px,3vw,42px); text-shadow:0 0 12px rgba(242,167,75,.18); opacity:.5; }
  .ring { position:absolute; top:54%; width:clamp(18px,2.3vw,35px); aspect-ratio:1; border:clamp(3px,.25vw,5px) solid #161817; border-radius:50%; box-shadow:inset 0 0 0 1px #5b5141,0 4px 5px #070302; transition:transform .4s ease; }
  .ring--left{right:8%}.ring--right{left:8%}

  :global(.storm-canvas){z-index:8!important;pointer-events:none}.frost{z-index:9;background:radial-gradient(ellipse,transparent 30%,rgba(135,163,178,.12) 67%,rgba(203,220,226,.18));mix-blend-mode:screen;transition:opacity 3s}.vignette{z-index:12;background:radial-gradient(ellipse,transparent 37%,rgba(0,3,6,.43) 76%,rgba(0,2,4,.88));transition:opacity 3s}.threshold-flare{z-index:10;opacity:0;background:radial-gradient(ellipse,rgba(255,241,190,.98),rgba(229,154,66,.7) 28%,transparent 66%);transform:scale(.2);transition:opacity 3s,transform 3s cubic-bezier(.2,.8,.2,1)}
  .door-prompt,.arrival-copy{position:absolute;z-index:15;left:50%;margin:0;text-align:center;letter-spacing:.18em;text-transform:uppercase;text-shadow:0 2px 12px #000;opacity:0;transition:opacity 1.2s,transform 1.2s}.door-prompt{bottom:7%;transform:translate(-50%,10px);color:rgba(239,216,177,.78);font-size:clamp(.68rem,1.1vw,.85rem)}.arrival-copy{top:14%;transform:translate(-50%,14px);color:#f4d59b;font-size:clamp(.85rem,1.4vw,1.15rem)}
  .controls{position:absolute;z-index:30;inset:auto clamp(16px,3vw,42px) clamp(16px,3vw,32px);display:flex;align-items:center;justify-content:space-between;pointer-events:none}.skip,.sound{pointer-events:auto;border:0;color:rgba(229,221,207,.58);background:rgba(3,7,10,.3);font:500 .68rem/1 Georgia,serif;letter-spacing:.14em;text-transform:uppercase;cursor:pointer;backdrop-filter:blur(8px)}.skip{padding:.7rem 0;background:transparent}.sound{display:flex;align-items:center;gap:.6rem;padding:.65rem .8rem;border:1px solid rgba(224,204,170,.16)}.skip:hover,.sound:hover{color:#f1d5a5}.sound-icon{width:12px;height:12px;border-left:5px solid currentColor;border-top:4px solid transparent;border-bottom:4px solid transparent;position:relative}.sound-icon::after{content:'';position:absolute;left:3px;top:-5px;width:7px;height:8px;border-right:1px solid;border-radius:50%;opacity:.25}.sound[aria-pressed=true] .sound-icon::after{opacity:1}audio{display:none}

  .tavern-world{z-index:2;opacity:0;overflow:hidden;transform:scale(1.08);background:radial-gradient(circle at 50% 48%,#6c3315,#26150d 31%,#100b08 72%);transition:opacity 4s,transform 5s cubic-bezier(.2,.75,.25,1),filter 3s}.tavern-world::before{content:'';position:absolute;inset:0;background:repeating-linear-gradient(0deg,transparent 0 14%,rgba(0,0,0,.16) 14.5% 15%),linear-gradient(90deg,rgba(0,0,0,.64),transparent 28% 72%,rgba(0,0,0,.64))}.beam{position:absolute;top:-12%;width:9%;height:125%;background:linear-gradient(90deg,#120a06,#4b2816,#170b07);box-shadow:0 0 25px #080403}.beam--left{left:18%;transform:rotate(-3deg)}.beam--right{right:18%;transform:rotate(3deg)}.shelf{position:absolute;top:28%;width:23%;height:36%;border-block:12px solid #351c10;background:repeating-linear-gradient(90deg,#18130e 0 8%,#7e4b26 8.5% 11%,#27180f 11.5% 16%);box-shadow:0 10px 22px #080403}.shelf--left{left:2%}.shelf--right{right:2%}
  .hearth{position:absolute;left:50%;top:36%;width:min(23vw,270px);height:min(34vh,290px);transform:translateX(-50%);border:clamp(16px,2vw,28px) solid #30251e;border-radius:44% 44% 0 0;background:radial-gradient(ellipse at 50% 90%,#fff1a3 0 5%,#ef8a2d 18%,#a13712 38%,#100704 63%);box-shadow:0 0 80px rgba(225,104,27,.45),inset 0 0 30px #000}.hearth span{position:absolute;bottom:8%;left:45%;width:16%;height:46%;border-radius:50%;background:linear-gradient(#ffe9a4,#f18a25 50%,transparent);transform-origin:bottom;animation:flame 1.3s ease-in-out infinite alternate}.hearth span:nth-child(2){left:27%;height:31%;animation-delay:-.6s}.hearth span:nth-child(3){left:61%;height:36%;animation-delay:-.9s}.table{position:absolute;left:50%;bottom:-10%;width:min(72vw,960px);height:34%;transform:translateX(-50%) perspective(500px) rotateX(58deg);background:repeating-linear-gradient(90deg,#2a1309 0 17%,#4f2712 17.5% 32%,#211006 32.5% 34%);border:8px solid #160b06;box-shadow:0 -16px 40px #090403}.dust{position:absolute;inset:0;background-image:radial-gradient(circle,#efc57d 0 1px,transparent 1.5px);background-size:91px 73px;opacity:.14;animation:dust-rise 9s linear infinite}

  [data-state=light-appears] .beacon{opacity:.68}[data-state=camera-approach] .camera{opacity:.75;transform:scale(.72)}[data-state=camera-approach] .beacon{opacity:1;transform:translate(-50%,-50%) scale(1.4)}
  [data-state=door-visible] .camera,[data-state=door-idle] .camera,[data-state=door-opening] .camera,[data-state=light-invades] .camera{opacity:1;transform:scale(1)}
  [data-state=door-visible] .stone-arch,[data-state=door-idle] .stone-arch,[data-state=door-opening] .stone-arch,[data-state=light-invades] .stone-arch{opacity:1}
  [data-state=door-idle] .door{cursor:pointer}[data-state=door-idle] .door-prompt{opacity:1;transform:translate(-50%,0)}[data-state=door-idle] .door:hover .door-leaf,[data-state=door-idle] .door:focus-visible .door-leaf{filter:brightness(1.25);box-shadow:inset 0 0 38px #080403,0 0 30px rgba(235,151,60,.3)}[data-state=door-idle] .door:hover .ring{transform:rotate(-12deg)}
  [data-state=door-opening] .door-leaf--left,[data-state=light-invades] .door-leaf--left,[data-state=crossing] .door-leaf--left,[data-state=storm-behind] .door-leaf--left{transform:rotateY(-82deg)}
  [data-state=door-opening] .door-leaf--right,[data-state=light-invades] .door-leaf--right,[data-state=crossing] .door-leaf--right,[data-state=storm-behind] .door-leaf--right{transform:rotateY(82deg)}
  [data-state=light-invades] .threshold-flare{opacity:.74;transform:scale(.72)}[data-state=crossing] .threshold-flare{opacity:1;transform:scale(1.8)}[data-state=crossing] .camera{transform:scale(2.2);opacity:.2;transition:transform 3s cubic-bezier(.2,.75,.2,1),opacity 2.7s}
  [data-state=storm-behind] .cold-world,[data-state=storm-behind] .camera,[data-state=tavern-reveal] .cold-world,[data-state=tavern-reveal] .camera{opacity:0}
  [data-state=storm-behind] .tavern-world,[data-state=tavern-reveal] .tavern-world,[data-state=camera-adjust] .tavern-world,[data-state=pause-moment] .tavern-world,[data-state=blog-transition] .tavern-world,[data-state=interface-reveal] .tavern-world{opacity:1;transform:scale(1)}
  [data-state=storm-behind] .threshold-flare{opacity:.5;transform:scale(2.1)}[data-state=tavern-reveal] .threshold-flare,[data-state=camera-adjust] .threshold-flare,[data-state=pause-moment] .threshold-flare{opacity:0;transform:scale(2.4)}[data-state=tavern-reveal] .frost,[data-state=camera-adjust] .frost,[data-state=pause-moment] .frost{opacity:0}[data-state=camera-adjust] .tavern-world{filter:brightness(1.12) saturate(1.08)}[data-state=pause-moment] .arrival-copy{opacity:1;transform:translate(-50%,0)}
  .site-preview{position:absolute;z-index:22;inset:0;width:100%;height:100%;border:0;background:#0a1026;opacity:0;transform:scale(1.035);pointer-events:none;transition:opacity 5s,transform 5s cubic-bezier(.2,.75,.2,1)}[data-state=interface-reveal] .site-preview{opacity:1;transform:scale(1)}
  @keyframes camera-sway{0%,100%{translate:-5px 2px}45%{translate:6px -4px}70%{translate:2px 3px}}@keyframes cloud-drift{to{transform:translate3d(3%,-2%,0) scale(1.04)}}@keyframes flame{from{transform:scaleX(.8) rotate(-4deg)}to{transform:scaleX(1.15) rotate(5deg)}}@keyframes dust-rise{to{background-position:18px -73px}}
  @media(max-width:640px){.camera{transform:scale(.36)}.stone-arch{width:min(78vw,340px);height:72vh}.door{width:min(57vw,250px);height:55vh;transform:translate(-50%,-40%)}.mountain{width:86%}.shelf{opacity:.6}.door-prompt{bottom:10%;width:100%}}
  @media(prefers-reduced-motion:reduce){.night-sky::after,.camera,.hearth span,.dust{animation:none!important}.experience *{transition-duration:.3s!important}}
</style>

<script>
  import { setWelcomeSeenCookie, shouldSkipWelcome } from '../../lib/welcome';

  const initializeExperience = () => {
    const root = document.getElementById('experience-root') as HTMLElement | null;
    const door = document.getElementById('door') as HTMLButtonElement | null;
    const skip = document.getElementById('skip-intro') as HTMLButtonElement | null;
    const sound = document.getElementById('sound-toggle') as HTMLButtonElement | null;
    const audio = document.getElementById('ambient-audio') as HTMLAudioElement | null;
    if (!root || !door || !skip || !sound || !audio) return;

    const replay = new URLSearchParams(location.search).has('replay');
    const hasSeen = shouldSkipWelcome();
    if (hasSeen && !replay) { location.replace('/index'); return; }
    skip.hidden = !hasSeen;

    const reduced = matchMedia('(prefers-reduced-motion: reduce)').matches;
    const storm = (window as any).__rnm_storm;
    const duration = (key: string) => Number(root.dataset[key] || 0);
    const wait = (ms: number) => new Promise<void>(resolve => setTimeout(resolve, reduced ? Math.min(ms, 180) : ms));
    let complete = false;

    const state = (name: string) => {
      root.dataset.state = name;
      if (name === 'light-appears') storm?.setVisibility(.82);
      if (name === 'camera-approach') { storm?.setWind(.86); storm?.setIntensity(.9); }
      if (name === 'door-visible') { storm?.setWind(.72); storm?.setVisibility(.7); }
      if (name === 'door-idle') { storm?.setWind(.58); storm?.setIntensity(.75); }
      if (name === 'door-opening') { storm?.setWind(.42); storm?.setIntensity(.6); }
      if (name === 'light-invades') { storm?.setGlobalAlpha(.72); storm?.setIntensity(.45); }
      if (name === 'crossing') { storm?.setGlobalAlpha(.3); storm?.setIntensity(.22); }
      if (name === 'storm-behind') { storm?.setGlobalAlpha(.06); storm?.setIntensity(.04); }
    };
    const finish = () => {
      if (complete) return;
      complete = true;
      setWelcomeSeenCookie();
      localStorage.setItem('rnm_welcome_completed', String(Date.now()));
      location.replace('/index');
    };
    const preview = () => {
      if (root.querySelector('.site-preview')) return;
      const frame = document.createElement('iframe');
      frame.className = 'site-preview'; frame.src = '/index'; frame.title = 'Página inicial do Runas na Mesa'; frame.tabIndex = -1;
      frame.setAttribute('aria-hidden','true'); root.append(frame);
    };
    const waitForDoor = () => new Promise<void>(resolve => door.addEventListener('click', () => { door.disabled = true; resolve(); }, { once:true }));

    const run = async () => {
      if (reduced) { state('tavern-reveal'); await wait(300); finish(); return; }
      await wait(duration('stormAlone')); state('light-appears');
      await wait(duration('lightAppears')); state('camera-approach');
      await wait(duration('cameraApproach')); state('door-visible');
      await wait(duration('doorVisible')); state('door-idle'); door.disabled = false;
      await waitForDoor(); state('door-opening');
      await wait(duration('doorOpening')); state('light-invades');
      await wait(duration('lightTransition')); state('crossing');
      await wait(duration('crossing')); state('storm-behind');
      await wait(duration('stormBehind')); state('tavern-reveal');
      await wait(duration('tavernReveal')); state('camera-adjust');
      await wait(duration('cameraAdjust')); state('pause-moment');
      await wait(duration('pauseMoment')); preview(); state('blog-transition');
      await wait(duration('blogTransition')); state('interface-reveal');
      await wait(duration('interfaceReveal')); finish();
    };
    sound.addEventListener('click', () => {
      const enabled = sound.getAttribute('aria-pressed') !== 'true';
      sound.setAttribute('aria-pressed', String(enabled)); sound.setAttribute('aria-label', enabled ? 'Desativar som ambiente' : 'Ativar som ambiente');
      audio.volume = .3; if (enabled) audio.play().catch(() => sound.setAttribute('aria-pressed','false')); else audio.pause();
    });
    skip.addEventListener('click', finish);
    run();
  };
  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', initializeExperience, { once:true }); else initializeExperience();
</script>
