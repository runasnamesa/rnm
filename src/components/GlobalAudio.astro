---
import { WELCOME_CONFIG } from "../config/welcome.config";
---

<audio
  id="global-ambient-audio"
  autoplay
  loop
  preload="auto"
  playsinline
  transition:persist="ambient-audio"
  data-volume={String(WELCOME_CONFIG.audio.volume)}
>
  <source src={WELCOME_CONFIG.audio.src} type="audio/mp4" />
</audio>

<script>
  const AUDIO_POSITION_KEY = "rnm_audio_position";

  // O elemento é preservado pelo View Transitions; o estado salvo cobre remontagens completas.
  const initializeAudio = () => {
      const audioEl = document.getElementById(
        "global-ambient-audio",
      ) as HTMLAudioElement;
      if (!audioEl) return;

      // Apenas na primeira inicialização real (evita resetar durante navegação)
      if (!(window as any).audioInitialized) {
        (window as any).audioInitialized = true;

        const savedVolume = localStorage.getItem("rnm_audio_volume");
        const savedPlaying = localStorage.getItem("rnm_audio_playing");
        const savedPosition = sessionStorage.getItem(AUDIO_POSITION_KEY);

        // Volume inicial da config, ou o valor salvo pelo usuário
        const defaultVolume = Number(
          document.getElementById('global-ambient-audio')?.dataset.volume ?? '0.25',
        );
        audioEl.volume = savedVolume ? parseFloat(savedVolume) : defaultVolume;

        if (savedPosition) {
          const restorePosition = () => {
            const position = parseFloat(savedPosition);
            if (Number.isFinite(position) && position < audioEl.duration) {
              audioEl.currentTime = position;
            }
          };

          if (audioEl.readyState >= 1) {
            restorePosition();
          } else {
            audioEl.addEventListener('loadedmetadata', restorePosition, { once: true });
          }
        }

        // Tenta tocar se for a primeira visita ou se o usuário deixou ativado
        if (savedPlaying === "true" || savedPlaying === null) {
          const playPromise = audioEl.play();
          if (playPromise !== undefined) {
            playPromise.then(() => {
               localStorage.setItem("rnm_audio_playing", "true");
            }).catch(() => {
              console.log("Autoplay bloqueado pelo navegador. Aguardando primeira interação para tocar.");
              
              // Se o navegador bloqueou, tentamos tocar no primeiro clique/interação na tela
              const startOnInteraction = () => {
                // Se o usuário já não pausou manualmente
                if (localStorage.getItem("rnm_audio_playing") !== "false") {
                  audioEl.play().then(() => {
                    localStorage.setItem("rnm_audio_playing", "true");
                    // Força o AudioToggle a atualizar visualmente
                    audioEl.dispatchEvent(new Event('play'));
                  }).catch(() => {});
                }
                document.removeEventListener('click', startOnInteraction);
                document.removeEventListener('keydown', startOnInteraction);
              };

              document.addEventListener('click', startOnInteraction);
              document.addEventListener('keydown', startOnInteraction);
            });
          }
        }
      }
  };

  const audioEl = document.getElementById("global-ambient-audio") as HTMLAudioElement | null;
  audioEl?.addEventListener('timeupdate', () => {
    sessionStorage.setItem(AUDIO_POSITION_KEY, String(audioEl.currentTime));
  });

  initializeAudio();
  document.addEventListener('DOMContentLoaded', initializeAudio);
  document.addEventListener('astro:page-load', initializeAudio);
</script>
